<?xml version="1.0" encoding="utf-8"?>
<!--
    Stránka RecipeActualPage slouží pro aktuální vážení zakázky.
    Obsahuje přehled zakázky, výběr aktivní váhy, carousel surovin a spodní ovládací tlačítka.
-->
<Page
    x:Class="RCP_WT1.Vizualizace.RecipeActualPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RCP_WT1.Vizualizace"
    Background="Transparent">

    <Page.Resources>
        <!-- Velikost a vycentrování ikon v levém navigačním panelu. -->
        <x:Double x:Key="NavigationViewItemIconSize">28</x:Double>
        <x:Double x:Key="NavigationViewItemOnLeftIconBoxWidth">48</x:Double>
        <x:Double x:Key="NavigationViewItemOnLeftIconBoxHeight">48</x:Double>
        <Thickness x:Key="NavigationViewItemMargin">0,2,0,2</Thickness>

        <!-- Jednotný styl položek levého menu podle předchozích oken. -->
        <Style TargetType="NavigationViewItem">
            <Setter Property="Height" Value="64"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </Page.Resources>

    <!-- Kořenový Grid sjednocuje průhledné pozadí stránky s předchozími okny. -->
    <Grid Background="Transparent">

        <!-- Hlavní navigační rozložení stránky -->
        <NavigationView
        x:Name="RootNav"
        PaneDisplayMode="Left"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        IsPaneToggleButtonVisible="True"
        OpenPaneLength="220"
        CompactPaneLength="80"
        Background="Transparent">

            <!-- Průhledné pozadí a odstranění výchozích linek NavigationView podle předchozích oken. -->
            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent"/>
                <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
                <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent"/>
            </NavigationView.Resources>

            <!-- Levé navigační menu s akcemi aktuálního vážení -->
            <NavigationView.MenuItems>

                <!-- Přihlášení / zobrazení aktuálně přihlášeného uživatele -->
                <NavigationViewItem
                x:Name="BtnLogin"
                Tapped="UserPanel_Tapped">

                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_people_28_color.svg"/>
                    </NavigationViewItem.Icon>

                    <StackPanel>
                        <TextBlock
                        x:Name="TxtLoginCaption"
                        Text="Přihlášení"
                        FontSize="16"/>

                        <TextBlock
                        x:Name="TxtLoginUser"
                        Visibility="Collapsed"
                        FontSize="11"
                        Opacity="0.7"/>
                    </StackPanel>
                </NavigationViewItem>

                <!-- Otevření technologického postupu PDF -->
                <NavigationViewItem
                x:Name="BtnPdf"
                Content="Technologický postup"
                Visibility="Collapsed"
                Tapped="BtnPDF_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_document_28_color.svg"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Přerušení aktuální zakázky -->
                <NavigationViewItem
                x:Name="BtnPrerusit"
                Content="Přerušit zakázku"
                Tapped="BtnPrerusitVazeni_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_pause_job_28_color.svg"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Ukončení nebo dokončení aktuální zakázky -->
                <NavigationViewItem
                x:Name="BtnUkoncit"
                Content="Ukončit zakázku"
                Tapped="BtnUkoncitVazeni_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_complete_job_28_color.svg"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>

            <!-- Spodní část navigace s návratem a logem -->
            <NavigationView.PaneFooter>
                <Grid
                MinWidth="80"
                HorizontalAlignment="Stretch"
                Margin="0,0,0,10">

                    <StackPanel
                    HorizontalAlignment="Stretch"
                    Spacing="6">

                        <!-- Návrat na přehled zakázek -->
                        <NavigationViewItem
                        Content="Zpět"
                        Tapped="BtnBack_Tapped">
                            <NavigationViewItem.Icon>
                                <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_back_screen_28_color.svg"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <!-- Logo aplikace ve spodní části navigace -->
                        <Grid Height="46">
                            <Image
                            Source="ms-appx:///Assets/Artos1_logo.png"
                            Width="38"
                            Height="38"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Stretch="Uniform"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </NavigationView.PaneFooter>

            <!-- Hlavní obsah stránky -->
            <Grid
            Margin="16,12,16,12"
            RowSpacing="10"
            Background="Transparent">

                <!-- Rozdělení stránky na záhlaví, stav, informace, carousel a spodní akce -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Záhlaví stránky -->
                <StackPanel Grid.Row="0" Spacing="4">
                    <TextBlock
                    Text="Aktuální vážení"
                    FontSize="24"
                    FontWeight="SemiBold"/>

                    <TextBlock
                    x:Name="TxtPageDescription"
                    Text="Průběh vážení aktuální zakázky"
                    FontSize="13"
                    Opacity="0.7"/>
                </StackPanel>

                <!-- Stavový informační panel -->
                <InfoBar
                x:Name="InfoStatus"
                Grid.Row="1"
                IsOpen="False"
                IsClosable="False"
                Severity="Informational"/>

                <!-- Souhrnná karta s údaji aktuální zakázky -->
                <Border
                Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1.5"
                CornerRadius="8"
                Padding="10">

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.4*"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="0.9*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Receptura" FontSize="13" Opacity="0.7"/>
                            <TextBlock
                            x:Name="RecipeName_Label"
                            FontSize="15"
                            FontWeight="SemiBold"
                            TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Zakázka" FontSize="13" Opacity="0.7"/>
                            <TextBlock
                            x:Name="JobNo_Label"
                            FontSize="15"
                            FontWeight="SemiBold"
                            TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="2">
                            <TextBlock Text="Šarže" FontSize="13" Opacity="0.7"/>
                            <TextBlock
                            x:Name="BatchNo_Label"
                            FontSize="15"
                            FontWeight="SemiBold"
                            TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Spacing="2">
                            <TextBlock Text="Velikost várky" FontSize="13" Opacity="0.7"/>
                            <TextBlock
                            x:Name="VelikostVarky_Label"
                            FontSize="15"
                            FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Spacing="2">
                            <TextBlock Text="Číslo várky" FontSize="13" Opacity="0.7"/>
                            <TextBlock
                            x:Name="CisloVarky_Label"
                            FontSize="15"
                            FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Oblast výběru váhy a carouselu surovin -->
                <Grid Grid.Row="3" RowSpacing="6">
                    <!-- Rozdělení stránky na záhlaví, stav, informace, carousel a spodní akce -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Horní řádek s tlačítky vah a tarou -->
                    <Grid Grid.Row="0" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Tlačítka pro přepnutí aktivní váhy -->
                        <StackPanel
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="10">

                            <Button
                            x:Name="BtnWeight1"
                            Content="Váha 1"
                            Tag="0"
                            Width="96"
                            Height="42"
                            FontSize="15"
                            Click="WeightButton_Click"/>

                            <Button
                            x:Name="BtnWeight2"
                            Content="Váha 2"
                            Tag="1"
                            Width="96"
                            Height="42"
                            FontSize="15"
                            Click="WeightButton_Click"/>

                            <Button
                            x:Name="BtnWeight3"
                            Content="Váha 3"
                            Tag="2"
                            Width="96"
                            Height="42"
                            FontSize="15"
                            Click="WeightButton_Click"/>

                            <Button
                            x:Name="BtnWeight4"
                            Content="Váha 4"
                            Tag="3"
                            Width="96"
                            Height="42"
                            FontSize="15"
                            Click="WeightButton_Click"/>

                            <Button
                            x:Name="BtnWeight5"
                            Content="Váha 5"
                            Tag="4"
                            Width="96"
                            Height="42"
                            FontSize="15"
                            Click="WeightButton_Click"/>
                        </StackPanel>

                        <!-- Tlačítko pro vynulování / taru váhy -->
                        <Button
                        x:Name="BtnTare"
                        Grid.Column="1"
                        Content="VYNULOVAT"
                        Width="130"
                        Height="42"
                        FontSize="15"
                        Click="BtnTare_Click"/>
                    </Grid>

                    <!-- Karta s carouselovým zobrazením vážených položek -->
                    <Border
                    Grid.Row="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1.5"
                    CornerRadius="12"
                    Padding="0">

                        <Grid>
                            <!-- Plátno, do kterého se dynamicky vykreslují karty surovin -->
                            <Canvas
                            x:Name="CarouselCanvas"
                            Background="Transparent"
                            MinHeight="300"
                            PointerPressed="CarouselCanvas_PointerPressed"
                            PointerReleased="CarouselCanvas_PointerReleased"
                            PointerCanceled="CarouselCanvas_PointerCanceled"
                            SizeChanged="CarouselCanvas_SizeChanged"/>

                            <!-- Zobrazení aktuální hmotnosti z vybrané váhy -->
                            <StackPanel
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="12,10,0,0"
                            Spacing="0">

                                <TextBlock
                                Text="Aktuální hmotnost"
                                FontSize="13"
                                Opacity="0.7"/>

                                <TextBlock
                                x:Name="AktualniVahaLabel"
                                Text="--- kg"
                                FontSize="26"
                                FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Spodní ovládací tlačítka carouselu a vážení -->
                <Grid Grid.Row="4" Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Posun carouselu vlevo -->
                    <Button
                    x:Name="BtnLeft"
                    Grid.Column="0"
                    Content="⯇"
                    Width="54"
                    Height="48"
                    FontSize="24"
                    Click="BtnLeft_Click"
                    Background="{ThemeResource LayerFillColorAltBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1.5"/>

                    <!-- Posun carouselu vpravo -->
                    <Button
                    x:Name="BtnRight"
                    Grid.Column="1"
                    Content="⯈"
                    Width="54"
                    Height="48"
                    FontSize="24"
                    Margin="8,0,0,0"
                    Click="BtnRight_Click"
                    Background="{ThemeResource LayerFillColorAltBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1.5"/>

                    <!-- Pozastavení vážení kvůli vysypání váhy -->
                    <Button
                    x:Name="BtnDumpScale"
                    Grid.Column="3"
                    Content="Vysypat váhu"
                    Width="125"
                    Height="48"
                    FontSize="15"
                    Click="BtnDumpScale_Click"
                    Background="{ThemeResource LayerFillColorAltBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1.5"/>

                    <!-- Reset aktuálního vážení -->
                    <Button
                    x:Name="BtnResetVazeni"
                    Grid.Column="4"
                    Content="Reset vážení"
                    Width="125"
                    Height="48"
                    FontSize="15"
                    Margin="8,0,0,0"
                    Click="BtnReset_Click"
                    Background="{ThemeResource LayerFillColorAltBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1.5"/>

                    <!-- Vytvoření nové várky po dokončení aktuální -->
                    <Button
                    x:Name="BtnNovaVarka"
                    Grid.Column="6"
                    Content="Nová várka"
                    Width="125"
                    Height="48"
                    FontSize="15"
                    Click="BtnNovaVarka_Click"
                    Background="{ThemeResource LayerFillColorAltBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1.5"/>
                </Grid>
            </Grid>
        </NavigationView>
    </Grid>
</Page>
