<?xml version="1.0" encoding="utf-8"?>
<!--
    Stránka RecipeDetailPage slouží pro zobrazení detailu receptury.
    Vzhled je sjednocený se stránkou RecipeEditPage.
    Levý panel má stejné rozměry, stejné barevné SVG ikony a stejné průhledné pozadí.
    Pravá část používá stejný styl karet, stejné pozadí a horní tlačítko pro obnovení v pravém rohu.
-->
<Page
    x:Class="RCP_WT1.Vizualizace.RecipeDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <!-- Stejné rozměry ikon jako v RecipeEditPage. -->
        <x:Double x:Key="NavigationViewItemIconSize">28</x:Double>
        <x:Double x:Key="NavigationViewItemOnLeftIconBoxWidth">48</x:Double>
        <x:Double x:Key="NavigationViewItemOnLeftIconBoxHeight">48</x:Double>
        <Thickness x:Key="NavigationViewItemMargin">0,2,0,2</Thickness>

        <!-- Jednotný styl položek levého menu. -->
        <Style TargetType="NavigationViewItem">
            <Setter Property="Height" Value="64"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </Page.Resources>

    <!-- Kořenový Grid umožňuje zobrazit horní vysouvací panel nad NavigationView. -->
    <Grid Background="Transparent">

        <!-- Levý navigační panel ve stejném stylu jako RecipeEditPage. -->
        <NavigationView
            x:Name="RootNav"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsPaneToggleButtonVisible="True"
            OpenPaneLength="220"
            CompactPaneLength="80"
            Background="Transparent">

            <!-- Odstranění výchozích linek a sjednocení pozadí levého panelu i pravé části. -->
            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent"/>
                <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
                <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent"/>
            </NavigationView.Resources>

            <!-- Levé menu s informacemi o receptuře a zakázce. -->
            <NavigationView.MenuItems>

                <!-- Přihlášení / odhlášení uživatele. -->
                <NavigationViewItem
                    x:Name="BtnLogin"
                    Tapped="UserPanel_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_people_28_color.svg"/>
                    </NavigationViewItem.Icon>

                    <StackPanel Spacing="1">
                        <TextBlock
                            x:Name="TxtLoginCaption"
                            Text="Přihlášení"
                            FontSize="16"
                            FontWeight="SemiBold"/>

                        <TextBlock
                            x:Name="TxtLoginUser"
                            Visibility="Collapsed"
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </NavigationViewItem>

                <!-- Zobrazení názvu receptury. -->
                <NavigationViewItem>
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_document_28_color.svg"/>
                    </NavigationViewItem.Icon>

                    <StackPanel Spacing="1">
                        <TextBlock Text="Název receptury" FontSize="13"/>
                        <Grid
                            Width="135"
                            Height="18">
                            <Grid.Clip>
                                <RectangleGeometry Rect="0,0,135,18"/>
                            </Grid.Clip>

                            <TextBlock
                                x:Name="TxtRecipeName"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="NoWrap"
                                MaxLines="1">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="TxtRecipeNameTransform"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </NavigationViewItem>

                <!-- Zadání nebo změna názvu zakázky. -->
                <NavigationViewItem
                    x:Name="BtnJobNo"
                    Tapped="BtnJobNo_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_edit_28_color.svg"/>
                    </NavigationViewItem.Icon>

                    <StackPanel Spacing="1">
                        <TextBlock Text="Název zakázky" FontSize="13"/>
                        <Grid
                            Width="135"
                            Height="18">
                            <Grid.Clip>
                                <RectangleGeometry Rect="0,0,135,18"/>
                            </Grid.Clip>

                            <TextBlock
                                x:Name="TxtJobNo"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="NoWrap"
                                MaxLines="1">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="TxtJobNoTransform"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </NavigationViewItem>

                <!-- Zadání nebo výběr šarže. -->
                <NavigationViewItem
                    x:Name="BtnBatchNo"
                    Tapped="BtnBatchNo_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_document_28_color.svg"/>
                    </NavigationViewItem.Icon>

                    <StackPanel Spacing="3">
                        <TextBlock Text="Název šarže" FontSize="13"/>

                        <Grid
                            Width="135"
                            Height="18">
                            <Grid.Clip>
                                <RectangleGeometry Rect="0,0,135,18"/>
                            </Grid.Clip>

                            <TextBlock
                                x:Name="TxtBatchNo"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="NoWrap"
                                MaxLines="1">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="TxtBatchNoTransform"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>

                        <!-- Skrytý výběr historické šarže, který se používá při práci s historií. -->
                        <ComboBox
                            x:Name="CmbHistoryBatch"
                            Width="1"
                            Height="1"
                            Opacity="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            DisplayMemberPath="Text"
                            SelectedValuePath="BatchIndex"
                            SelectionChanged="CmbHistoryBatch_SelectionChanged">

                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="MinHeight" Value="44"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                    </StackPanel>
                </NavigationViewItem>

                <!-- Zadání nebo změna množství receptury. -->
                <NavigationViewItem
                    x:Name="BtnAmount"
                    Tapped="BtnAmount_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_recipe_batch_size_28_color.svg"/>
                    </NavigationViewItem.Icon>

                    <StackPanel Spacing="1">
                        <TextBlock x:Name="TxtAmountCaption" Text="Množství receptu" FontSize="13"/>
                        <Grid
                            Width="135"
                            Height="18">
                            <Grid.Clip>
                                <RectangleGeometry Rect="0,0,135,18"/>
                            </Grid.Clip>

                            <TextBlock
                                x:Name="TxtAmount"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="NoWrap"
                                MaxLines="1">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="TxtAmountTransform"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </NavigationViewItem>

                <!-- Zadání nebo změna počtu várek. -->
                <NavigationViewItem
                    x:Name="BtnBatchCount"
                    Tapped="BtnBatchCount_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_data_trending_28_color.svg"/>
                    </NavigationViewItem.Icon>

                    <StackPanel Spacing="1">
                        <TextBlock Text="Počet várek" FontSize="13"/>
                        <Grid
                            Width="135"
                            Height="18">
                            <Grid.Clip>
                                <RectangleGeometry Rect="0,0,135,18"/>
                            </Grid.Clip>

                            <TextBlock
                                x:Name="TxtBatchCount"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="NoWrap"
                                MaxLines="1">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="TxtBatchCountTransform"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </NavigationViewItem>

            </NavigationView.MenuItems>

            <!-- Spodní část levého menu: návrat a logo. Obnovit je přesunuté do horní pravé části stránky. -->
            <NavigationView.PaneFooter>
                <Grid
                    MinWidth="80"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,10">

                    <StackPanel
                        HorizontalAlignment="Stretch"
                        Spacing="6">

                        <!-- Návrat na předchozí stránku. -->
                        <NavigationViewItem
                            Content="Zpět"
                            Tapped="BtnBack_Tapped">
                            <NavigationViewItem.Icon>
                                <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_back_screen_28_color.svg"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <!-- Logo aplikace. -->
                        <Grid Height="54">
                            <Image
                                Source="ms-appx:///Assets/Artos1_logo.png"
                                Width="42"
                                Height="42"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Stretch="Uniform"/>
                        </Grid>

                    </StackPanel>
                </Grid>
            </NavigationView.PaneFooter>

            <!-- Pravý obsah stránky ve stejném pozadí jako RecipeEditPage. -->
            <Grid Background="Transparent">

                <Grid
                    Padding="6,18,18,18"
                    RowSpacing="12"
                    Background="Transparent">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Horní karta: nadpis, popis a tlačítko pro ruční obnovení. -->
                    <Border
                        Grid.Row="0"
                        CornerRadius="14"
                        Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel
                                Grid.Column="0"
                                Spacing="2"
                                VerticalAlignment="Center">

                                <TextBlock
                                    x:Name="TxtPageTitle"
                                    Text="Detail receptury"
                                    FontSize="24"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                                <TextBlock
                                    x:Name="TxtPageDescription"
                                    Text="Přehled receptury, dávky a surovin"
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <!-- Ruční obnovení detailu receptury z databáze. -->
                            <Button
                                x:Name="BtnRefresh"
                                Grid.Column="1"
                                Width="40"
                                Height="36"
                                Padding="0"
                                VerticalAlignment="Center"
                                Click="BtnRefresh_Click">
                                <ImageIcon
                                    Width="24"
                                    Height="24"
                                    Source="ms-appx:///Assets/MenuIcons/ic_fluent_refresh_28_color.svg"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Souhrnné hodnoty receptury. -->
                    <Grid Grid.Row="1" ColumnSpacing="8">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Karta s celkovým počtem kusů. -->
                        <Border
                            x:Name="PanelTotalPcs"
                            Grid.Column="0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12">

                            <StackPanel Spacing="4">
                                <TextBlock Text="Celkem kusů" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="TxtTotalPcs" Text="—" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Karta s celkovou hmotností receptury. -->
                        <Border
                            Grid.Column="1"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12">

                            <StackPanel Spacing="4">
                                <TextBlock Text="Celková hmotnost" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="TxtTotalKg" Text="—" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Hlavní karta se sestavou receptury. -->
                    <Border
                        Grid.Row="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="14"
                        Padding="12"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">

                        <Grid RowSpacing="8">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Nadpis tabulky se sestavou receptury. -->
                            <TextBlock
                                Text="Sestava receptury"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                            <!-- Hlavička tabulky materiálů. -->
                            <Grid
                                Grid.Row="1"
                                Padding="10,8"
                                ColumnSpacing="14"
                                Background="{ThemeResource LayerFillColorDefaultBrush}">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="HeaderCode" Text="Kód" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="Materiál" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="2" x:Name="HeaderDavka" Text="Požadováno" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="3" x:Name="HeaderBaseDavka" Text="Původní" FontWeight="SemiBold" FontSize="14" Visibility="Collapsed" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="4" Text="Tolerance" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock x:Name="HeaderUser" Grid.Column="5" Text="Vážil" FontWeight="SemiBold" FontSize="14" Visibility="Collapsed" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </Grid>

                            <!-- Tabulka materiálů a položek receptury. -->
                            <ListView
                                x:Name="MaterialsTable"
                                Grid.Row="2"
                                SelectionMode="Single"
                                Background="Transparent"
                                Padding="0"
                                Margin="0,2,0,0">

                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                        <Setter Property="MinHeight" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>

                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Datový řádek materiálu nebo základu. -->
                                        <Border
                                            Padding="10"
                                            CornerRadius="12"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}">

                                            <Grid ColumnSpacing="14" MinHeight="40">

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="110"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding MaterialCislo}" FontSize="16" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="1" Text="{Binding MaterialName}" FontSize="16" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="2" Text="{Binding DavkaText}" FontSize="15" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="3" Text="{Binding BaseDavkaText}" FontSize="15" VerticalAlignment="Center" Visibility="{Binding BaseDavkaVisibility}"/>
                                                <TextBlock Grid.Column="4" Text="{Binding ToleranceText}" FontSize="15" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="5" Text="{Binding UserName}" FontSize="15" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Visibility="{Binding UserVisibility}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <!-- Spodní akční panel pro spuštění nebo naplánování receptury. -->
                    <Grid Grid.Row="3" ColumnSpacing="8">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Spuštění receptury / zakázky. -->
                        <Button
                            x:Name="BtnStartRecipe"
                            Grid.Column="0"
                            MinHeight="48"
                            FontSize="15"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Click="StartRecipe_Click">

                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <ImageIcon Width="24" Height="24" Source="ms-appx:///Assets/MenuIcons/ic_fluent_send_28_color.svg"/>
                                <TextBlock Text="Spustit recepturu" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Naplánování receptury / zakázky. -->
                        <Button
                            x:Name="BtnPlanRecipe"
                            Grid.Column="1"
                            MinHeight="48"
                            FontSize="15"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Click="PlanRecipe_Click">

                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <ImageIcon Width="24" Height="24" Source="ms-appx:///Assets/MenuIcons/ic_fluent_document_28_color.svg"/>
                                <TextBlock Text="Naplánovat recepturu" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
        </NavigationView>

        <!-- Horní vysouvací informační panel.
             Je vložený mimo NavigationView, takže je na středu celé stránky / okna. -->
        <Border
            x:Name="InfoToast"
            Margin="0,12,0,0"
            Padding="14,12"
            VerticalAlignment="Top"
            HorizontalAlignment="Center"
            Width="560"
            MaxWidth="560"
            CornerRadius="18"
            BorderThickness="1.5"
            Visibility="Collapsed"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}">

            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>

            <Border.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition
                        FromHorizontalOffset="0"
                        FromVerticalOffset="-90"
                        IsStaggeringEnabled="False"/>
                </TransitionCollection>
            </Border.Transitions>

            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border
                    Width="44"
                    Height="44"
                    CornerRadius="14"
                    VerticalAlignment="Center"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}">

                    <Image
                        x:Name="InfoToastIcon"
                        Width="28"
                        Height="28"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Stretch="Uniform"
                        Source="ms-appx:///Assets/MenuIcons/ic_fluent_info_28_color.svg"/>
                </Border>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="2">

                    <TextBlock
                        x:Name="InfoToastTitle"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        TextTrimming="CharacterEllipsis"
                        Text="Receptura"/>

                    <TextBlock
                        x:Name="InfoToastMessage"
                        FontSize="13"
                        LineHeight="18"
                        MaxLines="2"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap"
                        TextTrimming="CharacterEllipsis"
                        Text=""/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
