<?xml version="1.0" encoding="utf-8"?>
<!--
    Stránka RecipePreSelectPage slouží pro správu/editaci položek.
    Používá se pro práci se skupinami, materiály a recepturami.

    Rozložení je sjednocené s okny JobPage, SettingPage a RecipePage:
    - levý NavigationView používá stejné rozměry a barevné SVG ikony,
    - pravá část je složená z karet s ThemeResource barvami,
    - tlačítko Obnovit je v horní kartě vpravo,
    - informační panel je horní vysouvací toast uprostřed celé stránky,
    - kliknutí na řádek pouze vybere položku, akce se provádí tlačítky v levém panelu.
-->
<Page
    x:Class="RCP_WT1.Vizualizace.RecipePreSelectPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RCP_WT1.Vizualizace"
    Background="Transparent">

    <Page.Resources>
        <!-- Stejné rozměry ikon jako v oknech JobPage, SettingPage a RecipePage. -->
        <x:Double x:Key="NavigationViewItemIconSize">28</x:Double>
        <x:Double x:Key="NavigationViewItemOnLeftIconBoxWidth">48</x:Double>
        <x:Double x:Key="NavigationViewItemOnLeftIconBoxHeight">48</x:Double>
        <Thickness x:Key="NavigationViewItemMargin">0,2,0,2</Thickness>

        <!-- Jednotný styl položek levého NavigationView. -->
        <Style TargetType="NavigationViewItem">
            <Setter Property="Height" Value="64"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </Page.Resources>

    <!-- Kořenový Grid drží NavigationView a nad ním horní toast panel. -->
    <Grid Background="Transparent">

        <!-- Hlavní navigační rozložení stránky. -->
        <NavigationView
            x:Name="RootNav"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsPaneToggleButtonVisible="True"
            OpenPaneLength="220"
            CompactPaneLength="80"
            Background="Transparent">

            <!-- Průhledná pozadí a odstranění výchozích linek NavigationView. -->
            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent"/>
                <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
                <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent"/>
            </NavigationView.Resources>

            <!-- Levé navigační menu s hlavními akcemi stránky. -->
            <NavigationView.MenuItems>

                <!-- Přihlášení / odhlášení uživatele. -->
                <NavigationViewItem
                    x:Name="BtnLogin"
                    Tapped="UserPanel_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_people_28_color.svg"/>
                    </NavigationViewItem.Icon>

                    <StackPanel Spacing="1">
                        <TextBlock
                            x:Name="TxtLoginCaption"
                            Text="Přihlášení"
                            FontSize="16"
                            FontWeight="SemiBold"/>

                        <TextBlock
                            x:Name="TxtLoginUser"
                            Visibility="Collapsed"
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </NavigationViewItem>

                <!-- Vytvoření nové položky podle aktuálního režimu stránky. -->
                <NavigationViewItem
                    x:Name="BtnNew"
                    Content="Nový"
                    Tapped="BtnNew_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_add_circle_28_color.svg"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Úprava aktuálně vybrané položky. -->
                <NavigationViewItem
                    x:Name="BtnEdit"
                    Content="Upravit"
                    Tapped="BtnEdit_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_edit_28_color.svg"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Smazání aktuálně vybrané položky. -->
                <NavigationViewItem
                    x:Name="BtnDelete"
                    Content="Smazat"
                    Tapped="BtnDelete_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_delete_28_color.svg"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Přepnutí nebo nastavení skupiny jako základ. -->
                <NavigationViewItem
                    x:Name="BtnZaklad"
                    Content="Základ"
                    Visibility="Collapsed"
                    Tapped="BtnZaklad_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_base_material_28_color.svg"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>

            <!-- Spodní část navigace s návratem a logem aplikace. -->
            <NavigationView.PaneFooter>
                <Grid
                    MinWidth="80"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,10">

                    <StackPanel
                        HorizontalAlignment="Stretch"
                        Spacing="6">

                        <!-- Návrat na obrazovku receptur. -->
                        <NavigationViewItem
                            x:Name="BtnBack"
                            Content="Zpět"
                            Tapped="BtnBack_Tapped">
                            <NavigationViewItem.Icon>
                                <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_back_screen_28_color.svg"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <!-- Logo aplikace ve spodní části levého panelu. -->
                        <Grid Height="54">
                            <Image
                                Source="ms-appx:///Assets/Artos1_logo.png"
                                Width="42"
                                Height="42"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Stretch="Uniform"/>
                        </Grid>

                    </StackPanel>
                </Grid>
            </NavigationView.PaneFooter>

            <!-- Pravý obsah stránky. -->
            <Grid Background="Transparent">

                <Grid
                    Padding="6,18,18,18"
                    RowSpacing="12"
                    Background="Transparent">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Horní karta: název stránky, popis a tlačítko Obnovit vpravo nahoře. -->
                    <Border
                        Grid.Row="0"
                        CornerRadius="14"
                        Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>

                            <!-- Název a popis aktuálního režimu stránky. -->
                            <StackPanel
                                Grid.Column="0"
                                Spacing="2"
                                VerticalAlignment="Center">

                                <TextBlock
                                    x:Name="TxtPageTitle"
                                    Text="Editace položek"
                                    FontSize="24"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                                <TextBlock
                                    x:Name="TxtPageDescription"
                                    Text="Správa skupin, materiálů a receptur"
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <!-- Ruční obnovení dat v seznamu. -->
                            <Button
                                x:Name="BtnRefresh"
                                Grid.Column="1"
                                Width="40"
                                Height="36"
                                Padding="0"
                                VerticalAlignment="Center"
                                Click="BtnRefresh_Click">
                                <ImageIcon
                                    Width="24"
                                    Height="24"
                                    Source="ms-appx:///Assets/MenuIcons/ic_fluent_refresh_28_color.svg"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Hlavní karta se seznamem editovaných položek. -->
                    <Border
                        Grid.Row="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="14"
                        Padding="12"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">

                        <Grid RowSpacing="8">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Nadpis aktuálního seznamu. -->
                            <TextBlock
                                x:Name="MainCaption"
                                Grid.Row="0"
                                Text="Seznam"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                            <!-- Hlavička tabulky. -->
                            <Grid
                                Grid.Row="1"
                                Padding="10,8"
                                ColumnSpacing="14"
                                Background="{ThemeResource LayerFillColorDefaultBrush}">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="CodeColumnHeader" Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    x:Name="TxtCodeHeader"
                                    Text="Kód"
                                    FontWeight="SemiBold"
                                    FontSize="14"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                                <TextBlock
                                    Grid.Column="1"
                                    Text="Název"
                                    FontWeight="SemiBold"
                                    FontSize="14"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </Grid>

                            <!-- Tabulka zobrazující skupiny, materiály nebo receptury podle aktuálního režimu.
                                 Kliknutí na řádek pouze vybere položku. Editace/smazání je přes levý panel. -->
                            <ListView
                                x:Name="Table"
                                Grid.Row="2"
                                SelectionMode="Single"
                                SelectionChanged="Table_SelectionChanged"
                                KeyDown="Table_KeyDown"
                                Background="Transparent"
                                Padding="0"
                                Margin="0,2,0,0">

                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                        <Setter Property="MinHeight" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>

                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Padding="10"
                                            CornerRadius="12"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}">

                                            <Grid ColumnSpacing="14" MinHeight="40">

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="160"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Kód položky. U skupin se skrývá podle CodeVisibility. -->
                                                <TextBlock
                                                    Text="{Binding Code}"
                                                    FontSize="16"
                                                    FontWeight="SemiBold"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding CodeVisibility}"
                                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                    TextTrimming="CharacterEllipsis"/>

                                                <!-- Název položky. -->
                                                <TextBlock
                                                    Grid.Column="1"
                                                    Text="{Binding Name}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                    TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </NavigationView>

        <!-- Horní vysouvací informační panel.
             Je mimo NavigationView, proto je zarovnaný na střed celé stránky / okna.
             Obsah se plní z RecipePreSelectPage.xaml.cs metodou ZobrazInfo. -->
        <Border
            x:Name="InfoToast"
            Margin="0,12,0,0"
            Padding="14,12"
            VerticalAlignment="Top"
            HorizontalAlignment="Center"
            Width="560"
            MaxWidth="560"
            CornerRadius="18"
            BorderThickness="1.5"
            Visibility="Collapsed"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}">

            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>

            <Border.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition
                        FromHorizontalOffset="0"
                        FromVerticalOffset="-90"
                        IsStaggeringEnabled="False"/>
                </TransitionCollection>
            </Border.Transitions>

            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Barevná ikona podle typu hlášení. -->
                <Border
                    Width="44"
                    Height="44"
                    CornerRadius="14"
                    VerticalAlignment="Center"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}">

                    <Image
                        x:Name="InfoToastIcon"
                        Width="28"
                        Height="28"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Stretch="Uniform"
                        Source="ms-appx:///Assets/MenuIcons/ic_fluent_alert_28_color.svg"/>
                </Border>

                <!-- Text informačního panelu. -->
                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="2">

                    <TextBlock
                        x:Name="InfoToastTitle"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        TextTrimming="CharacterEllipsis"
                        Text="Editace"/>

                    <TextBlock
                        x:Name="InfoToastMessage"
                        FontSize="13"
                        LineHeight="18"
                        MaxLines="2"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap"
                        TextTrimming="CharacterEllipsis"
                        Text=""/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Page>
