<?xml version="1.0" encoding="utf-8"?>
<!--
    Stránka sumarizace výroby.
    Levý panel je vizuálně sjednocený s obrazovkami receptur.
    Pravá část je přepracovaná jako přehledový dashboard s filtry, souhrnnými kartami a tabulkou.
-->
<Page
    x:Class="RCP_WT1.Vizualizace.SumarizationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Page.Resources>
        <!-- Stejné rozměry ikon jako v ostatních hlavních obrazovkách. -->
        <x:Double x:Key="NavigationViewItemIconSize">28</x:Double>
        <x:Double x:Key="NavigationViewItemOnLeftIconBoxWidth">48</x:Double>
        <x:Double x:Key="NavigationViewItemOnLeftIconBoxHeight">48</x:Double>
        <Thickness x:Key="NavigationViewItemMargin">0,2,0,2</Thickness>

        <!-- Jednotný styl položek levého menu. -->
        <Style TargetType="NavigationViewItem">
            <Setter Property="Height" Value="64"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <!-- Popisky v kartách a filtrech. -->
        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Hodnoty v souhrnných kartách. -->
        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </Page.Resources>

    <!-- Kořenový Grid umožňuje zobrazit InfoToast nad NavigationView a zarovnat ho na střed celé stránky. -->
    <Grid Background="Transparent">

        <!-- Levý navigační panel ve stejném stylu jako RecipeEditPage. -->
        <NavigationView
            x:Name="RootNav"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsPaneToggleButtonVisible="True"
            OpenPaneLength="220"
            CompactPaneLength="80"
            Background="Transparent">

            <!-- Odstranění výchozích linek a pozadí NavigationView. -->
            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent"/>
                <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
                <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent"/>
            </NavigationView.Resources>

            <!-- Levé menu pro přepínání typu sumarizace. -->
            <NavigationView.MenuItems>

                <!-- Přihlášení / odhlášení uživatele. -->
                <NavigationViewItem
                    x:Name="BtnLogin"
                    Tapped="UserPanel_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_people_28_color.svg"/>
                    </NavigationViewItem.Icon>

                    <StackPanel Spacing="1">
                        <TextBlock
                            x:Name="TxtLoginCaption"
                            Text="Přihlášení"
                            FontSize="16"
                            FontWeight="SemiBold"/>

                        <TextBlock
                            x:Name="TxtLoginUser"
                            Visibility="Collapsed"
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </NavigationViewItem>

                <!-- Sumarizace základových hmot. -->
                <NavigationViewItem
                    x:Name="BtnZaklad"
                    Content="Suma základů"
                    Tapped="BtnZaklad_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_recipe_groups_28_color.svg"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Sumarizace receptur. -->
                <NavigationViewItem
                    x:Name="BtnKlasika"
                    Content="Suma receptů"
                    Tapped="BtnKlasika_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_receipt_28_color.svg"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Sumarizace materiálů. -->
                <NavigationViewItem
                    x:Name="BtnMaterialy"
                    Content="Suma materiálů"
                    Tapped="BtnMaterialy_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_materials_28_color.svg"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>

            <!-- Spodní část levého menu: návrat a logo. -->
            <NavigationView.PaneFooter>
                <Grid
                    MinWidth="80"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,10">

                    <StackPanel
                        HorizontalAlignment="Stretch"
                        Spacing="6">

                        <!-- Návrat zpět. -->
                        <NavigationViewItem
                            x:Name="BtnBack"
                            Content="Zpět"
                            Tapped="BtnBack_Tapped">
                            <NavigationViewItem.Icon>
                                <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_back_screen_28_color.svg"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <!-- Logo aplikace. -->
                        <Grid Height="54">
                            <Image
                                Source="ms-appx:///Assets/Artos1_logo.png"
                                Width="42"
                                Height="42"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Stretch="Uniform"/>
                        </Grid>

                    </StackPanel>
                </Grid>
            </NavigationView.PaneFooter>

            <!-- Pravý obsah stránky. -->
            <Grid Background="Transparent">

                <Grid
                    Padding="6,18,18,18"
                    RowSpacing="12"
                    Background="Transparent">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Horní karta: nadpis, popis a tlačítko pro ruční obnovení. -->
                    <Border
                        Grid.Row="0"
                        CornerRadius="14"
                        Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel
                                Grid.Column="0"
                                Spacing="2"
                                VerticalAlignment="Center">

                                <TextBlock
                                    x:Name="TxtPageTitle"
                                    Text="Přehled výroby"
                                    FontSize="24"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                                <TextBlock
                                    x:Name="TxtPageDescription"
                                    Text="Sumarizace výroby podle základů, receptur a materiálů"
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <!-- Ruční obnovení aktuálního přehledu. -->
                            <Button
                                Grid.Column="1"
                                Width="40"
                                Height="36"
                                Padding="0"
                                VerticalAlignment="Center"
                                Click="BtnRefresh_Click">
                                <ImageIcon
                                    Width="24"
                                    Height="24"
                                    Source="ms-appx:///Assets/MenuIcons/ic_fluent_refresh_28_color.svg"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Panel filtrů období a operátora. -->
                    <Border
                        Grid.Row="1"
                        CornerRadius="14"
                        Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">

                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Text="Filtry přehledu"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                            <Grid Grid.Row="1" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1.7*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Filtr roku. -->
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Rok" Style="{StaticResource MutedTextStyle}"/>
                                    <ComboBox
                                        x:Name="CbYear"
                                        MinHeight="40"
                                        HorizontalAlignment="Stretch"
                                        FontSize="14"
                                        SelectionChanged="FilterChanged"/>
                                </StackPanel>

                                <!-- Filtr měsíce. -->
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Měsíc" Style="{StaticResource MutedTextStyle}"/>
                                    <ComboBox
                                        x:Name="CbMonth"
                                        MinHeight="40"
                                        HorizontalAlignment="Stretch"
                                        FontSize="14"
                                        SelectionChanged="FilterChanged"/>
                                </StackPanel>

                                <!-- Filtr týdne. -->
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="Týden" Style="{StaticResource MutedTextStyle}"/>
                                    <ComboBox
                                        x:Name="CbWeek"
                                        MinHeight="40"
                                        HorizontalAlignment="Stretch"
                                        FontSize="14"
                                        SelectionChanged="FilterChanged"/>
                                </StackPanel>

                                <!-- Filtr dne. -->
                                <StackPanel Grid.Column="3" Spacing="4">
                                    <TextBlock Text="Den" Style="{StaticResource MutedTextStyle}"/>
                                    <ComboBox
                                        x:Name="CbDay"
                                        MinHeight="40"
                                        HorizontalAlignment="Stretch"
                                        FontSize="14"
                                        SelectionChanged="FilterChanged"/>
                                </StackPanel>

                                <!-- Filtr operátora. -->
                                <StackPanel Grid.Column="4" Spacing="4">
                                    <TextBlock Text="Operátor" Style="{StaticResource MutedTextStyle}"/>
                                    <ComboBox
                                        x:Name="CbOperator"
                                        MinHeight="40"
                                        HorizontalAlignment="Stretch"
                                        FontSize="14"
                                        SelectionChanged="FilterChanged"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Souhrnné karty nad tabulkou. -->
                    <Grid Grid.Row="2" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Počet položek. -->
                        <Border
                            Grid.Column="0"
                            CornerRadius="14"
                            Padding="12"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Položek" Style="{StaticResource MutedTextStyle}"/>
                                <TextBlock x:Name="TxtPocetPolozek" Text="0" Style="{StaticResource MetricValueStyle}"/>
                            </StackPanel>
                        </Border>

                        <!-- Suma požadovaného množství. -->
                        <Border
                            Grid.Column="1"
                            CornerRadius="14"
                            Padding="12"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="TxtPozadovanoCaption" Text="Požadováno" Style="{StaticResource MutedTextStyle}"/>
                                <TextBlock x:Name="TxtPozadovano" Text="—" Style="{StaticResource MetricValueStyle}"/>
                            </StackPanel>
                        </Border>

                        <!-- Suma naváženého množství. -->
                        <Border
                            Grid.Column="2"
                            CornerRadius="14"
                            Padding="12"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="TxtNavazenoCaption" Text="Naváženo" Style="{StaticResource MutedTextStyle}"/>
                                <TextBlock x:Name="TxtNavazeno" Text="—" Style="{StaticResource MetricValueStyle}"/>
                            </StackPanel>
                        </Border>

                        <!-- Přesnost nebo počet položek podle režimu. -->
                        <Border
                            Grid.Column="3"
                            CornerRadius="14"
                            Padding="12"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="TxtPresnostCaption" Text="Průměrná přesnost" Style="{StaticResource MutedTextStyle}"/>
                                <TextBlock x:Name="TxtPresnost" Text="—" Style="{StaticResource MetricValueStyle}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Hlavní karta se sumarizačními daty. -->
                    <Border
                        Grid.Row="3"
                        CornerRadius="14"
                        Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">

                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Nadpis tabulky. -->
                            <TextBlock
                                x:Name="TxtTableTitle"
                                Grid.Row="0"
                                Text="Suma základů"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                            <!-- Hlavička tabulky receptur a základů. -->
                            <Grid
                                x:Name="HeaderRecipes"
                                Grid.Row="1"
                                Padding="10,8"
                                ColumnSpacing="14"
                                Background="{ThemeResource LayerFillColorDefaultBrush}">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.4*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Receptura" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="Požadováno (kg)" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="Naváženo (kg)" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="3" Text="Rozdíl" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="4" Text="Přesnost %" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </Grid>

                            <!-- Hlavička tabulky materiálů. -->
                            <Grid
                                x:Name="HeaderMaterials"
                                Grid.Row="1"
                                Padding="10,8"
                                ColumnSpacing="14"
                                Visibility="Collapsed"
                                Background="{ThemeResource LayerFillColorDefaultBrush}">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Materiál" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="Naváženo (kg)" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </Grid>

                            <!-- Tabulka sumarizace receptur a základů. -->
                            <ListView
                                x:Name="GridRecipes"
                                Grid.Row="2"
                                SelectionMode="None"
                                Background="Transparent"
                                Padding="0"
                                Margin="0,2,0,0">

                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                        <Setter Property="MinHeight" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>

                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Jeden řádek sumarizační tabulky. -->
                                        <Border
                                            Padding="10"
                                            CornerRadius="12"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}">

                                            <Grid ColumnSpacing="14" MinHeight="40">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2.4*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding Name}" FontSize="16" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Poz}" FontSize="16" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Nav}" FontSize="16" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Diff}" FontSize="16" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Grid.Column="4" Text="{Binding Accuracy}" FontSize="16" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <!-- Tabulka sumarizace materiálů. -->
                            <ListView
                                x:Name="GridMaterials"
                                Grid.Row="2"
                                Visibility="Collapsed"
                                SelectionMode="None"
                                Background="Transparent"
                                Padding="0"
                                Margin="0,2,0,0">

                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                        <Setter Property="MinHeight" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>

                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Jeden řádek sumarizační tabulky. -->
                                        <Border
                                            Padding="10"
                                            CornerRadius="12"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}">

                                            <Grid ColumnSpacing="14" MinHeight="40">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding Nazev}" FontSize="16" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding NavazenoText}" FontSize="16" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </NavigationView>

        <!-- Horní vysouvací informační panel.
             Je vložený mimo NavigationView, takže je na středu celé stránky / okna. -->
        <Border
            x:Name="InfoToast"
            Margin="0,12,0,0"
            Padding="14,12"
            VerticalAlignment="Top"
            HorizontalAlignment="Center"
            Width="560"
            MaxWidth="560"
            CornerRadius="18"
            BorderThickness="1.5"
            Visibility="Collapsed"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}">

            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>

            <Border.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition
                        FromHorizontalOffset="0"
                        FromVerticalOffset="-90"
                        IsStaggeringEnabled="False"/>
                </TransitionCollection>
            </Border.Transitions>

            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border
                    Width="44"
                    Height="44"
                    CornerRadius="14"
                    VerticalAlignment="Center"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}">

                    <Image
                        x:Name="InfoToastIcon"
                        Width="28"
                        Height="28"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Stretch="Uniform"
                        Source="ms-appx:///Assets/MenuIcons/ic_fluent_info_28_color.svg"/>
                </Border>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="2">

                    <TextBlock
                        x:Name="InfoToastTitle"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        TextTrimming="CharacterEllipsis"
                        Text="Sumarizace"/>

                    <TextBlock
                        x:Name="InfoToastMessage"
                        FontSize="13"
                        LineHeight="18"
                        MaxLines="2"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap"
                        TextTrimming="CharacterEllipsis"
                        Text=""/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
