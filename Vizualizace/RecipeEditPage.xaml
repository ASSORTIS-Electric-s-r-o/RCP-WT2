<?xml version="1.0" encoding="utf-8"?>
<!--
    Stránka RecipeEditPage slouží pro editaci receptury.
    Vzhled je sjednocený s okny JobPage, SettingPage, RecipePage a RecipePreSelectPage.
    Levý panel obsahuje hlavní vlastnosti receptury a akce stránky.
    Pravá část obsahuje horní kartu s titulkem, tabulku surovin a spodní tlačítka pro přidání položek.
-->
<Page
    x:Class="RCP_WT1.Vizualizace.RecipeEditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RCP_WT1.Vizualizace"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <!-- Stejné rozměry ikon jako v ostatních hlavních obrazovkách. -->
        <x:Double x:Key="NavigationViewItemIconSize">28</x:Double>
        <x:Double x:Key="NavigationViewItemOnLeftIconBoxWidth">48</x:Double>
        <x:Double x:Key="NavigationViewItemOnLeftIconBoxHeight">48</x:Double>
        <Thickness x:Key="NavigationViewItemMargin">0,2,0,2</Thickness>

        <!-- Jednotný styl položek levého menu. -->
        <Style TargetType="NavigationViewItem">
            <Setter Property="Height" Value="64"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <!-- Tlumený text pro vedlejší informace. -->
        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Hlavní text hodnot v tabulce. -->
        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </Page.Resources>

    <!-- Kořenový Grid umožňuje zobrazit InfoToast nad NavigationView a zarovnat ho na střed celé stránky. -->
    <Grid Background="Transparent">

        <!-- Levý navigační panel ve stejném stylu jako předchozí obrazovky. -->
        <NavigationView
            x:Name="RootNav"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsPaneToggleButtonVisible="True"
            OpenPaneLength="220"
            CompactPaneLength="80"
            Background="Transparent">

            <!-- Odstranění výchozích linek a pozadí NavigationView. -->
            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent"/>
                <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
                <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent"/>
            </NavigationView.Resources>

            <!-- Horní část levého menu: přihlášení a editovatelné vlastnosti receptury. -->
            <NavigationView.MenuItems>

                <!-- Přihlášení / odhlášení uživatele. -->
                <NavigationViewItem
                    x:Name="BtnLogin"
                    Tapped="UserPanel_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_people_28_color.svg"/>
                    </NavigationViewItem.Icon>

                    <StackPanel Spacing="1">
                        <TextBlock
                            x:Name="TxtLoginCaption"
                            Text="Přihlášení"
                            FontSize="16"
                            FontWeight="SemiBold"/>

                        <TextBlock
                            x:Name="TxtLoginUser"
                            Visibility="Collapsed"
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </NavigationViewItem>

                <!-- Editace názvu receptury. -->
                <NavigationViewItem
                    x:Name="BtnRecipeName"
                    Tapped="BtnRecipeName_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_edit_28_color.svg"/>
                    </NavigationViewItem.Icon>

                    <StackPanel Spacing="1">
                        <TextBlock Text="Název receptury" FontSize="13"/>
                        <Grid
                            Width="135"
                            Height="18">
                            <Grid.Clip>
                                <RectangleGeometry Rect="0,0,135,18"/>
                            </Grid.Clip>

                            <TextBlock
                                x:Name="TxtRecipeName"
                                Text=""
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="NoWrap"
                                MaxLines="1">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="TxtRecipeNameTransform"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </NavigationViewItem>

                <!-- Editace kódu receptury. -->
                <NavigationViewItem
                    x:Name="BtnRecipeCode"
                    Tapped="BtnRecipeCode_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_edit_28_color.svg"/>
                    </NavigationViewItem.Icon>

                    <StackPanel Spacing="1">
                        <TextBlock Text="Kódové označení" FontSize="13"/>
                        <Grid
                            Width="135"
                            Height="18">
                            <Grid.Clip>
                                <RectangleGeometry Rect="0,0,135,18"/>
                            </Grid.Clip>

                            <TextBlock
                                x:Name="TxtRecipeCode"
                                Text=""
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="NoWrap"
                                MaxLines="1">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="TxtRecipeCodeTransform"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </NavigationViewItem>

                <!-- Výběr skupiny receptury. ComboBox se otevře kliknutím na celý řádek. -->
                <NavigationViewItem
                    x:Name="BtnRecipeGroup"
                    Tapped="BtnRecipeGroup_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_recipe_groups_28_color.svg"/>
                    </NavigationViewItem.Icon>

                    <StackPanel Spacing="3">
                        <TextBlock Text="Skupina" FontSize="13"/>

                        <Grid Width="135" Height="18">
                            <Grid.Clip>
                                <RectangleGeometry Rect="0,0,135,18"/>
                            </Grid.Clip>

                            <TextBlock
                                x:Name="TxtRecipeGroup"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="NoWrap"
                                MaxLines="1">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="TxtRecipeGroupTransform"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>

                        <ComboBox
                            x:Name="CmbRecipeGroup"
                            Width="1"
                            Height="1"
                            Opacity="0"
                            IsHitTestVisible="False"
                            DisplayMemberPath="Name"
                            SelectedValuePath="IDgrp"
                            SelectionChanged="CmbRecipeGroup_SelectionChanged"/>
                    </StackPanel>
                </NavigationViewItem>

                <!-- Editace velikosti várky. -->
                <NavigationViewItem
                    x:Name="BtnRecipeAmount"
                    Tapped="BtnRecipeAmount_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_recipe_batch_size_28_color.svg"/>
                    </NavigationViewItem.Icon>

                    <StackPanel Spacing="1">
                        <TextBlock Text="Velikost várky" FontSize="13"/>
                        <Grid
                            Width="135"
                            Height="18">
                            <Grid.Clip>
                                <RectangleGeometry Rect="0,0,135,18"/>
                            </Grid.Clip>

                            <TextBlock
                                x:Name="TxtRecipeAmount"
                                Text=""
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="NoWrap"
                                MaxLines="1">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="TxtRecipeAmountTransform"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </NavigationViewItem>

                <!-- Výběr technologického postupu PDF. -->
                <NavigationViewItem
                    x:Name="BtnRecipePdf"
                    Tapped="BtnRecipePdf_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_document_28_color.svg"/>
                    </NavigationViewItem.Icon>

                    <StackPanel Spacing="1">
                        <TextBlock Text="Tech. postup PDF" FontSize="13"/>
                        <Grid
                            Width="135"
                            Height="18">
                            <Grid.Clip>
                                <RectangleGeometry Rect="0,0,135,18"/>
                            </Grid.Clip>

                            <TextBlock
                                x:Name="TxtRecipePdf"
                                Text=""
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="NoWrap"
                                MaxLines="1">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="TxtRecipePdfTransform"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </NavigationViewItem>

            </NavigationView.MenuItems>

            <!-- Spodní část levého menu: PDF, uložení, návrat a logo. -->
            <NavigationView.PaneFooter>
                <Grid
                    MinWidth="80"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,10">

                    <StackPanel
                        HorizontalAlignment="Stretch"
                        Spacing="6">

                        <!-- Otevření náhledu PDF dokumentu. -->
                        <NavigationViewItem
                            x:Name="BtnShowPdf"
                            Content="Náhled PDF"
                            Visibility="Collapsed"
                            Tapped="BtnShowPdf_Tapped">
                            <NavigationViewItem.Icon>
                                <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_preview_28_color.svg"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <!-- Uložení receptury a položek. -->
                        <NavigationViewItem
                            x:Name="BtnSave"
                            Content="Uložit"
                            Tapped="BtnSave_Tapped">
                            <NavigationViewItem.Icon>
                                <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_save_28_color.svg"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <!-- Návrat zpět na přehled receptur. -->
                        <NavigationViewItem
                            x:Name="BtnBack"
                            Content="Zpět"
                            Tapped="BtnBack_Tapped">
                            <NavigationViewItem.Icon>
                                <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_back_screen_28_color.svg"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <!-- Logo aplikace. -->
                        <Grid Height="54">
                            <Image
                                Source="ms-appx:///Assets/Artos1_logo.png"
                                Width="42"
                                Height="42"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Stretch="Uniform"/>
                        </Grid>

                    </StackPanel>
                </Grid>
            </NavigationView.PaneFooter>

            <!-- Pravý obsah stránky. -->
            <Grid Background="Transparent">

                <Grid
                    Padding="6,18,18,18"
                    RowSpacing="12"
                    Background="Transparent">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Horní karta: nadpis, popis a tlačítko pro ruční obnovení. -->
                    <Border
                        Grid.Row="0"
                        CornerRadius="14"
                        Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel
                                Grid.Column="0"
                                Spacing="2"
                                VerticalAlignment="Center">

                                <TextBlock
                                    x:Name="TxtPageTitle"
                                    Text="Receptura"
                                    FontSize="24"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                                <TextBlock
                                    x:Name="TxtPageDescription"
                                    Text="Editace receptury a jejích surovin"
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <!-- Ruční obnovení receptury z databáze. -->
                            <Button
                                Grid.Column="1"
                                Width="40"
                                Height="36"
                                Padding="0"
                                VerticalAlignment="Center"
                                Click="BtnRefresh_Click">
                                <ImageIcon
                                    Width="24"
                                    Height="24"
                                    Source="ms-appx:///Assets/MenuIcons/ic_fluent_refresh_28_color.svg"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Hlavní karta s tabulkou surovin receptury. -->
                    <Border
                        Grid.Row="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="14"
                        Padding="12"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">

                        <Grid RowSpacing="8">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Titulek tabulky a akce nad vybraným řádkem. -->
                            <Grid Grid.Row="0" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    x:Name="TxtTableTitle"
                                    Grid.Column="0"
                                    Text="Suroviny receptury"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                                <!-- Tlačítka se zobrazí až po výběru řádku. -->
                                <StackPanel
                                    Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="6"
                                    VerticalAlignment="Center">

                                    <Button
                                        x:Name="BtnMoveUp"
                                        Width="40"
                                        Height="36"
                                        Padding="0"
                                        Visibility="Collapsed"
                                        Click="BtnMoveUp_Click">
                                        <ImageIcon
                                            Width="24"
                                            Height="24"
                                            Source="ms-appx:///Assets/MenuIcons/ic_fluent_row_move_up_28_color.svg"/>
                                    </Button>

                                    <Button
                                        x:Name="BtnMoveDown"
                                        Width="40"
                                        Height="36"
                                        Padding="0"
                                        Visibility="Collapsed"
                                        Click="BtnMoveDown_Click">
                                        <ImageIcon
                                            Width="24"
                                            Height="24"
                                            Source="ms-appx:///Assets/MenuIcons/ic_fluent_row_move_down_28_color.svg"/>
                                    </Button>

                                    <Button
                                        x:Name="BtnDelete"
                                        Width="40"
                                        Height="36"
                                        Padding="0"
                                        Visibility="Collapsed"
                                        Click="BtnDelete_Click">
                                        <ImageIcon
                                            Width="24"
                                            Height="24"
                                            Source="ms-appx:///Assets/MenuIcons/ic_fluent_delete_28_color.svg"/>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- Hlavička tabulky surovin. -->
                            <Grid
                                Grid.Row="1"
                                Padding="10,8"
                                ColumnSpacing="14"
                                Background="{ThemeResource LayerFillColorDefaultBrush}">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Pořadí" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="Materiál" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="Dávka" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="3" Text="Tolerance" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="4" Text="Vážit" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </Grid>

                            <!-- Tabulka položek receptury. Kliknutí na řádek pouze vybere řádek, akce jsou na tlačítkách. -->
                            <ListView
                                x:Name="Table"
                                Grid.Row="2"
                                SelectionMode="Single"
                                SelectionChanged="Table_SelectionChanged"
                                KeyDown="Table_KeyDown"
                                Background="Transparent"
                                Padding="0"
                                Margin="0,2,0,0">

                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                        <Setter Property="MinHeight" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>

                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Padding="10"
                                            CornerRadius="12"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}">

                                            <Grid ColumnSpacing="14" MinHeight="40">

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="70"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock
                                                    Text="{Binding RowNoText}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                                                <TextBlock
                                                    Grid.Column="1"
                                                    Text="{Binding MaterialName}"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                    TextTrimming="CharacterEllipsis"/>

                                                <!-- Editace dávky položky. -->
                                                <Button
                                                    Grid.Column="2"
                                                    Content="{Binding DavkaText}"
                                                    FontSize="14"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Center"
                                                    Click="BtnEditDavka_Click"/>

                                                <!-- Editace tolerance položky. -->
                                                <Button
                                                    Grid.Column="3"
                                                    Content="{Binding ToleranceText}"
                                                    FontSize="14"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Center"
                                                    Click="BtnEditTolerance_Click"/>

                                                <!-- Přepnutí, zda se položka má vážit. -->
                                                <Button
                                                    Grid.Column="4"
                                                    Content="{Binding VazitText}"
                                                    FontSize="14"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Center"
                                                    Click="BtnToggleVazit_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <!-- Spodní akční panel pro přidání základu nebo suroviny. -->
                    <Grid Grid.Row="2" ColumnSpacing="8">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Přidání základní receptury do aktuální receptury. -->
                        <Button
                            x:Name="BtnEditZaklad"
                            Grid.Column="0"
                            MinHeight="48"
                            FontSize="15"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Click="BtnEditZaklad_Click">

                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <ImageIcon Width="24" Height="24" Source="ms-appx:///Assets/MenuIcons/ic_fluent_recipe_groups_28_color.svg"/>
                                <TextBlock Text="Přidat základ" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Přidání materiálu do aktuální receptury. -->
                        <Button
                            x:Name="BtnEditMaterial"
                            Grid.Column="1"
                            MinHeight="48"
                            FontSize="15"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Click="BtnEditMaterial_Click">

                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <ImageIcon Width="24" Height="24" Source="ms-appx:///Assets/MenuIcons/ic_fluent_materials_28_color.svg"/>
                                <TextBlock Text="Přidat surovinu" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
        </NavigationView>

        <!-- Horní vysouvací informační panel.
             Je vložený mimo NavigationView, takže je na středu celé stránky / okna. -->
        <Border
            x:Name="InfoToast"
            Margin="0,12,0,0"
            Padding="14,12"
            VerticalAlignment="Top"
            HorizontalAlignment="Center"
            Width="560"
            MaxWidth="560"
            CornerRadius="18"
            BorderThickness="1.5"
            Visibility="Collapsed"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}">

            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>

            <Border.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition
                        FromHorizontalOffset="0"
                        FromVerticalOffset="-90"
                        IsStaggeringEnabled="False"/>
                </TransitionCollection>
            </Border.Transitions>

            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border
                    Width="44"
                    Height="44"
                    CornerRadius="14"
                    VerticalAlignment="Center"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}">

                    <Image
                        x:Name="InfoToastIcon"
                        Width="28"
                        Height="28"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Stretch="Uniform"
                        Source="ms-appx:///Assets/MenuIcons/ic_fluent_info_28_color.svg"/>
                </Border>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="2">

                    <TextBlock
                        x:Name="InfoToastTitle"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        TextTrimming="CharacterEllipsis"
                        Text="Receptura"/>

                    <TextBlock
                        x:Name="InfoToastMessage"
                        FontSize="13"
                        LineHeight="18"
                        MaxLines="2"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap"
                        TextTrimming="CharacterEllipsis"
                        Text=""/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
