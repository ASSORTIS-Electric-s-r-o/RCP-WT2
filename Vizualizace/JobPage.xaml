<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RCP_WT1.Vizualizace.JobPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RCP_WT1.Vizualizace">

    <Page.Resources>
        <local:JobStatusBackgroundConverter x:Key="JobStatusBackgroundConverter"/>

        <!-- Velikost a vycentrování ikon v NavigationView.
             Tyto hodnoty upravují přímo ikonový prostor položky, takže ikony
             zůstanou při zasunutí panelu na středu a nebudou se ořezávat. -->
        <x:Double x:Key="NavigationViewItemIconSize">28</x:Double>
        <x:Double x:Key="NavigationViewItemOnLeftIconBoxWidth">48</x:Double>
        <x:Double x:Key="NavigationViewItemOnLeftIconBoxHeight">48</x:Double>
        <Thickness x:Key="NavigationViewItemMargin">0,2,0,2</Thickness>

        <Style TargetType="NavigationViewItem">
            <Setter Property="Height" Value="64"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </Page.Resources>

    <Grid Background="Transparent">

        <NavigationView
            x:Name="RootNav"
        PaneDisplayMode="Left"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        IsPaneToggleButtonVisible="True"
        OpenPaneLength="220"
        CompactPaneLength="80"
        Background="Transparent">

            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent"/>
                <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
                <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent"/>
            </NavigationView.Resources>

            <NavigationView.MenuItems>

                <NavigationViewItem
                x:Name="BtnLogin"
                Tapped="UserPanel_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_people_28_color.svg"/>
                    </NavigationViewItem.Icon>

                    <StackPanel Spacing="1">
                        <TextBlock
                        x:Name="TxtLoginCaption"
                        Text="Přihlášení"
                        FontSize="16"
                        FontWeight="SemiBold"/>

                        <TextBlock
                        x:Name="TxtLoginUser"
                        Visibility="Collapsed"
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </NavigationViewItem>

                <NavigationViewItem
                x:Name="BtnRecipes"
                Content="Receptury"
                Tapped="BtnRecipesLeft_Click">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_receipt_28_color.svg"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem
                x:Name="BtnOpenRecipe"
                Content="Aktivní zakázka"
                Visibility="Collapsed"
                Tapped="OpenRecipe_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_active_job_28_color.svg"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem
                x:Name="BtnDetail"
                Content="Detail zakázky"
                Visibility="Collapsed"
                Tapped="DetailPage_Tapped">
                    <NavigationViewItem.Icon>
                        <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_jobs_28_color.svg"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>

            <NavigationView.PaneFooter>
                <Grid
                MinWidth="80"
                HorizontalAlignment="Stretch"
                Margin="0,0,0,10">

                    <StackPanel
                    HorizontalAlignment="Stretch"
                    Spacing="6">

                        <NavigationViewItem
                        x:Name="BtnScale"
                        Content="Zobrazení váhy"
                        Tapped="OpenScale_Click">
                            <NavigationViewItem.Icon>
                                <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_scale_display_28_color.svg"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem
                        x:Name="BtnSums"
                        Content="Přehled vážení"
                        Tapped="OpenSums_Click">
                            <NavigationViewItem.Icon>
                                <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_data_trending_28_color.svg"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem
                        x:Name="BtnVypocetZakladu"
                        Content="Výpočet základu"
                        Visibility="Collapsed"
                        Tapped="VypocetZakladu_Click">
                            <NavigationViewItem.Icon>
                                <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_add_circle_28_color.svg"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem
                        x:Name="BtnSettings"
                        Content="Nastavení"
                        Visibility="Collapsed"
                        Tapped="BtnSettingsLeft_Click">
                            <NavigationViewItem.Icon>
                                <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_options_28_color.svg"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <Grid Height="54">
                            <Image
                            Source="ms-appx:///Assets/Artos1_logo.png"
                            Width="42"
                            Height="42"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Stretch="Uniform"/>
                        </Grid>

                    </StackPanel>
                </Grid>
            </NavigationView.PaneFooter>

            <Grid Background="Transparent">

                <Grid
                Padding="6,18,18,18"
                RowSpacing="12"
                Background="Transparent">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border
                    Grid.Row="0"
                CornerRadius="14"
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="210"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock
                        Text="Zakázky"
                        FontSize="24"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                            <ComboBox
                        x:Name="StatusComboBox"
                        Grid.Column="1"
                        Width="210"
                        Height="36"
                        VerticalAlignment="Center"
                        SelectedValuePath="ID"
                        SelectionChanged="StatusComboBox_SelectionChanged">

                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontSize="15"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <ComboBox
                        x:Name="ShiftComboBox"
                        Grid.Column="2"
                        Width="180"
                        Height="36"
                        VerticalAlignment="Center"
                        SelectedValuePath="ID"
                        SelectionChanged="ShiftComboBox_SelectionChanged">

                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontSize="15"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <Button
                            Grid.Column="3"
                            Width="40"
                            Height="36"
                            Padding="0"
                            VerticalAlignment="Center"
                            Click="Refresh_Click">

                                <ImageIcon
                                Width="24"
                                Height="24"
                                Source="ms-appx:///Assets/MenuIcons/ic_fluent_refresh_28_color.svg"/>
                            </Button>

                        </Grid>
                    </Border>

                    <Border
                    Grid.Row="1"
                CornerRadius="14"
                Padding="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                        <ScrollViewer
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled">

                            <StackPanel
                        x:Name="DaysPanel"
                        Orientation="Horizontal"
                        Spacing="10"/>
                        </ScrollViewer>
                    </Border>

                    <Border
                    Grid.Row="2"
                CornerRadius="14"
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid
                        Grid.Row="0"
                        Height="0"
                        Opacity="0"
                        IsHitTestVisible="False">

                                <TextBlock
                            x:Name="ColReqAmountHeader"
                            Text="Množství"/>
                            </Grid>

                            <ListView
                        x:Name="JobsTable"
                        Grid.Row="1"
                        SelectionMode="Single"
                        SelectionChanged="JobsTable_SelectionChanged"
                        Background="Transparent"
                        Padding="0">

                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                        <Setter Property="MinHeight" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>

                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                    Padding="10"
                                    CornerRadius="12"
                                    Background="{Binding Status, Converter={StaticResource JobStatusBackgroundConverter}}">

                                            <Grid ColumnSpacing="14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="48"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            Spacing="2">

                                                    <TextBlock
                                                Text="{Binding RecipeName}"
                                                FontSize="17"
                                                FontWeight="SemiBold"
                                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                TextTrimming="CharacterEllipsis"/>

                                                    <StackPanel
                                                Orientation="Horizontal"
                                                Spacing="12">

                                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                                            <TextBlock
                                                        Text="Zakázka:"
                                                        Style="{StaticResource MutedTextStyle}"/>

                                                            <TextBlock
                                                        Text="{Binding JobNo}"
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                                        </StackPanel>

                                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                                            <TextBlock
                                                        Text="Šarže:"
                                                        Style="{StaticResource MutedTextStyle}"/>

                                                            <TextBlock
                                                        Text="{Binding BatchNo}"
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                                        </StackPanel>

                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Spacing="2">

                                                    <TextBlock
                                                Text="Množství"
                                                Style="{StaticResource MutedTextStyle}"/>

                                                    <TextBlock
                                                Text="{Binding ReqAmountPcsText}"
                                                Style="{StaticResource ValueTextStyle}"/>
                                                </StackPanel>

                                                <StackPanel
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Spacing="2">

                                                    <TextBlock
                                                Text="Počet várek"
                                                Style="{StaticResource MutedTextStyle}"/>

                                                    <TextBlock
                                                Text="{Binding ReqNumberBatch}"
                                                Style="{StaticResource ValueTextStyle}"/>
                                                </StackPanel>

                                                <Button
                                                Grid.Column="3"
                                                Width="40"
                                                Height="40"
                                                Padding="0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Visibility="{Binding DataContext.DeleteColumnVisibility, ElementName=JobsTable}"
                                                Click="DeleteJobRow_Click">

                                                    <ImageIcon
                                                    Width="24"
                                                    Height="24"
                                                    Source="ms-appx:///Assets/MenuIcons/ic_fluent_delete_28_color.svg"/>
                                                </Button>

                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                        </Grid>
                    </Border>

                </Grid>

            </Grid>
        </NavigationView>

        <!-- Horní vysouvací informační panel.
                 Panel je vložený mimo NavigationView, takže se centruje vůči celé stránce / oknu, ne pouze vůči pravé obsahové části.
                 Vzhled je řešen jako moderní WinUI toast: vlevo barevná SVG ikona, vpravo dva řádky textu. -->
        <Border
                x:Name="InfoToast"
                Margin="0,12,0,0"
                Padding="14,12"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Width="560"
                MaxWidth="560"
                CornerRadius="18"
                BorderThickness="1.5"
                Visibility="Collapsed"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource AccentFillColorDefaultBrush}">

            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>

            <Border.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition
                            FromHorizontalOffset="0"
                            FromVerticalOffset="-90"
                            IsStaggeringEnabled="False"/>
                </TransitionCollection>
            </Border.Transitions>

            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border
                        Width="44"
                        Height="44"
                        CornerRadius="14"
                        VerticalAlignment="Center"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}">

                    <Image
                            x:Name="InfoToastIcon"
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Stretch="Uniform"
                            Source="ms-appx:///Assets/MenuIcons/ic_fluent_info_28_color.svg"/>
                </Border>

                <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Spacing="2">

                    <TextBlock
                            x:Name="InfoToastTitle"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                            TextTrimming="CharacterEllipsis"
                            Text="Výroba"/>

                    <TextBlock
                            x:Name="InfoToastMessage"
                            FontSize="13"
                            LineHeight="18"
                            MaxLines="2"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap"
                            TextTrimming="CharacterEllipsis"
                            Text=""/>
                </StackPanel>
            </Grid>
        </Border>



    </Grid>
</Page>