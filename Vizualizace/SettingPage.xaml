<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RCP_WT1.Vizualizace.SettingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Page.Resources>
        <x:Double x:Key="NavigationViewItemIconSize">28</x:Double>
        <x:Double x:Key="NavigationViewItemOnLeftIconBoxWidth">48</x:Double>
        <x:Double x:Key="NavigationViewItemOnLeftIconBoxHeight">48</x:Double>
        <Thickness x:Key="NavigationViewItemMargin">0,2,0,2</Thickness>

        <Style TargetType="NavigationViewItem">
            <Setter Property="Height" Value="64"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </Page.Resources>

    <NavigationView
        x:Name="RootNav"
        PaneDisplayMode="Left"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        IsPaneToggleButtonVisible="True"
        OpenPaneLength="220"
        CompactPaneLength="80"
        Background="Transparent">

        <NavigationView.Resources>
            <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent"/>
            <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewPaneBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent"/>
        </NavigationView.Resources>

        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="BtnMySql" Content="MySQL" Tapped="BtnMySql_Tapped">
                <NavigationViewItem.Icon>
                    <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_database_28_color.svg"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <NavigationViewItem x:Name="BtnComm" Content="COMM" Tapped="BtnComm_Tapped">
                <NavigationViewItem.Icon>
                    <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_scale_display_28_color.svg"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <NavigationViewItem x:Name="BtnUsers" Content="Uživatelé" Tapped="BtnUsers_Tapped">
                <NavigationViewItem.Icon>
                    <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_people_list_28_color.svg"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <NavigationViewItem x:Name="BtnSystem" Content="Systém" Tapped="BtnSystem_Tapped">
                <NavigationViewItem.Icon>
                    <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_options_28_color.svg"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <NavigationViewItem x:Name="BtnParameters" Content="Parametry" Tapped="BtnParameters_Tapped">
                <NavigationViewItem.Icon>
                    <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_settings_28_color.svg"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <NavigationView.PaneFooter>
            <Grid MinWidth="80" HorizontalAlignment="Stretch" Margin="0,0,0,10">
                <StackPanel HorizontalAlignment="Stretch" Spacing="6">
                    <NavigationViewItem x:Name="BtnExit" Content="Ukončit" Tapped="BtnExit_Tapped">
                        <NavigationViewItem.Icon>
                            <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_dismiss_circle_28_color.svg"/>
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>

                    <NavigationViewItem x:Name="BtnBack" Content="Zpět" Tapped="BtnBack_Tapped">
                        <NavigationViewItem.Icon>
                            <ImageIcon Source="ms-appx:///Assets/MenuIcons/ic_fluent_back_screen_28_color.svg"/>
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>

                    <Grid Height="54">
                        <Image Source="ms-appx:///Assets/Artos1_logo.png" Width="42" Height="42" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </NavigationView.PaneFooter>

        <Grid Background="Transparent">
            <Grid Margin="16,12,16,12" RowSpacing="8" Background="Transparent">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="2">
                    <TextBlock x:Name="TxtPageTitle" Text="Nastavení" FontSize="24" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtPageDescription" Text="Nastavení aplikace a komunikace" FontSize="13" Opacity="0.7"/>
                </StackPanel>

                <Border Grid.Row="1" CornerRadius="14" Padding="10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button x:Name="BtnTestMySql" Width="110" Height="44" FontSize="15" Visibility="Collapsed" Click="BtnTestMySql_Click">Test spojení</Button>
                                <Button x:Name="BtnTestScale" Width="130" Height="44" FontSize="15" Visibility="Collapsed" Click="BtnTestScale_Click">Test váhy</Button>
                                <Border x:Name="SepTestComm" Width="1" Height="36" Visibility="Collapsed" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>
                                <Button x:Name="BtnTestAlibi" Width="130" Height="44" FontSize="15" Visibility="Collapsed" Click="BtnTestAlibi_Click">Test alibi</Button>
                                <Button x:Name="BtnUserAdd" Width="110" Height="44" FontSize="15" Visibility="Collapsed" Click="BtnUserAdd_Click">Přidat</Button>
                                <Border x:Name="SepUsers1" Width="1" Height="36" Visibility="Collapsed" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>
                                <Button x:Name="BtnUserEdit" Width="110" Height="44" FontSize="15" Visibility="Collapsed" Click="BtnUserEdit_Click">Upravit</Button>
                                <Border x:Name="SepUsers2" Width="1" Height="36" Visibility="Collapsed" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>
                                <Button x:Name="BtnUserDelete" Width="110" Height="44" FontSize="15" Visibility="Collapsed" Click="BtnUserDelete_Click">Smazat</Button>
                                <Button x:Name="BtnExportRecipes" Width="155" Height="44" FontSize="15" Visibility="Collapsed" Click="BtnExportRecipes_Click">Export receptur</Button>
                                <Border x:Name="SepSystemImportExport" Width="1" Height="36" Visibility="Collapsed" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>
                                <Button x:Name="BtnImportRecipes" Width="155" Height="44" FontSize="15" Visibility="Collapsed" Click="BtnImportRecipes_Click">Import receptur</Button>
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <Button Width="110" Height="44" FontSize="15" Click="SaveCurrent_Click">Uložit</Button>
                            <Button Width="110" Height="44" FontSize="15" Click="ReloadCurrent_Click">Načíst znovu</Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer x:Name="ContentScrollViewer" Grid.Row="2" Background="Transparent" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="8">
                        <Border x:Name="PanelMySql" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="14" Padding="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="MySQL" FontSize="18" FontWeight="SemiBold"/>
                                <Grid Padding="8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Server / IP" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtSqlIp" Tag="Server / IP" Grid.Row="0" Grid.Column="1" Height="36" FontSize="15"/>
                                    <TextBlock Grid.Row="1" Text="Databáze" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtSqlDb" Tag="Databáze" Grid.Row="1" Grid.Column="1" Height="36" FontSize="15"/>
                                    <TextBlock Grid.Row="2" Text="Uživatel" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtSqlUser" Tag="Uživatel databáze" Grid.Row="2" Grid.Column="1" Height="36" FontSize="15"/>
                                    <TextBlock Grid.Row="3" Text="Heslo" FontSize="15" VerticalAlignment="Center"/>
                                    <PasswordBox x:Name="TxtSqlPassword" Tag="Heslo databáze" Grid.Row="3" Grid.Column="1" Height="36" FontSize="15"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border x:Name="PanelComm" Visibility="Collapsed" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="14" Padding="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="COMM" FontSize="18" FontWeight="SemiBold"/>

                                <Grid Padding="8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Váha" FontSize="15" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="CmbScaleIndex" Grid.Row="0" Grid.Column="1" Height="36" FontSize="15" SelectionChanged="CmbScaleIndex_SelectionChanged"/>
                                    <TextBlock Grid.Row="1" Text="Povolena" FontSize="15" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="ChkScaleEnabled" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Text="Kopírovat z váhy" FontSize="15" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                        <ComboBox x:Name="CmbCopyFromScale" Width="190" Height="36" FontSize="15"/>
                                        <Button Content="Použít" MinWidth="90" Height="36" FontSize="14" FontWeight="SemiBold" Click="BtnCopyFromScale_Click"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Váha – připojení" FontSize="15" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <Grid Padding="8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Název váhy" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtScaleName" Tag="Název váhy" Grid.Row="0" Grid.Column="1" Height="36" FontSize="15"/>
                                    <TextBlock Grid.Row="1" Text="Typ komunikace" FontSize="15" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="CmbCommType" Grid.Row="1" Grid.Column="1" Height="36" FontSize="15" SelectionChanged="CmbCommType_SelectionChanged">
                                        <ComboBoxItem Content="COM"/>
                                        <ComboBoxItem Content="ETH"/>
                                    </ComboBox>
                                    <TextBlock x:Name="LblComPort" Grid.Row="2" Text="COM port" FontSize="15" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="CmbComPort" Grid.Row="2" Grid.Column="1" Height="36" FontSize="15" PlaceholderText="Vyberte COM port"/>
                                    <TextBlock x:Name="LblBaud" Grid.Row="3" Text="Baud" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtBaud" Tag="Baud" Grid.Row="3" Grid.Column="1" Height="36" FontSize="15"/>
                                    <TextBlock x:Name="LblParity" Grid.Row="4" Text="Parita" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtParity" Tag="Parita" Grid.Row="4" Grid.Column="1" Height="36" FontSize="15"/>
                                    <TextBlock x:Name="LblDataBits" Grid.Row="5" Text="Data bits" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtDataBits" Tag="Data bits" Grid.Row="5" Grid.Column="1" Height="36" FontSize="15"/>
                                    <TextBlock x:Name="LblStopBits" Grid.Row="6" Text="Stop bits" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtStopBits" Tag="Stop bits" Grid.Row="6" Grid.Column="1" Height="36" FontSize="15"/>
                                    <TextBlock x:Name="LblHandshake" Grid.Row="7" Text="Handshake" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtHandshake" Tag="Handshake" Grid.Row="7" Grid.Column="1" Height="36" FontSize="15"/>
                                    <TextBlock x:Name="LblHost" Grid.Row="8" Text="ETH host" FontSize="15" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtHost" Tag="ETH host" Grid.Row="8" Grid.Column="1" Height="36" FontSize="15" Visibility="Collapsed"/>
                                    <TextBlock x:Name="LblTcpPort" Grid.Row="9" Text="ETH port" FontSize="15" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtTcpPort" Tag="ETH port" Grid.Row="9" Grid.Column="1" Height="36" FontSize="15" Visibility="Collapsed"/>
                                </Grid>

                                <TextBlock Text="Příkaz a čtení dat" FontSize="15" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <Grid Padding="8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Adresa váhy" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtScaleAddress" Tag="Adresa váhy" Grid.Row="0" Grid.Column="1" Height="36" FontSize="15"/>
                                    <TextBlock Grid.Row="1" Text="Read příkaz" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtReadCommand" Tag="Read příkaz" Grid.Row="1" Grid.Column="1" Height="36" FontSize="15"/>
                                    <TextBlock Grid.Row="2" Text="Newline" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtNewline" Tag="Newline" Grid.Row="2" Grid.Column="1" Height="36" FontSize="15"/>
                                    <TextBlock Grid.Row="3" Text="Číst pasivně" FontSize="15" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="ChkScaleAsync" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="4" Text="Polling ms" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtPollMs" Tag="Polling ms" Grid.Row="4" Grid.Column="1" Height="36" FontSize="15"/>
                                    <TextBlock Grid.Row="5" Text="Timeout ms" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtTimeoutMs" Tag="Timeout ms" Grid.Row="5" Grid.Column="1" Height="36" FontSize="15"/>
                                </Grid>

                                <TextBlock Text="Formát zprávy" FontSize="15" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <Grid Padding="8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="90"/>
                                        <RowDefinition Height="90"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Display format" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtScaleFormat" Tag="Display format" Grid.Row="0" Grid.Column="1" Height="36" FontSize="15"/>
                                    <TextBlock Grid.Row="1" Text="TokenDefs" FontSize="15" VerticalAlignment="Top" Margin="0,12,0,0"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtTokenDefs" Tag="TokenDefs" Grid.Row="1" Grid.Column="1" FontSize="15" AcceptsReturn="True" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="2" Text="FieldMap" FontSize="15" VerticalAlignment="Top" Margin="0,12,0,0"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtFieldMap" Tag="FieldMap" Grid.Row="2" Grid.Column="1" FontSize="15" AcceptsReturn="True" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="3" Text="Dělící faktor" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtDisplayDivisor" Tag="Dělící faktor" Grid.Row="3" Grid.Column="1" Height="36" FontSize="15"/>
                                    <TextBlock Grid.Row="4" Text="Jednotky" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtUnitsFallback" Tag="Jednotky" Grid.Row="4" Grid.Column="1" Height="36" FontSize="15"/>
                                </Grid>

                                <TextBlock Text="Stavy váhy" FontSize="15" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <Grid Padding="8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="90"/>
                                        <RowDefinition Height="90"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="StatusMap" FontSize="15" VerticalAlignment="Top" Margin="0,12,0,0"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtStatusMap" Tag="StatusMap" Grid.Row="0" Grid.Column="1" FontSize="15" AcceptsReturn="True" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="1" Text="Status text map" FontSize="15" VerticalAlignment="Top" Margin="0,12,0,0"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtStatusTextMap" Tag="Status text map" Grid.Row="1" Grid.Column="1" FontSize="15" AcceptsReturn="True" TextWrapping="Wrap"/>
                                </Grid>

                                <TextBlock Text="Alibi" FontSize="15" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <Grid Padding="8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Povolit Alibi" FontSize="15" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="ChkEnableAlibi" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" Text="Store příkaz" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtAlibiStoreCommand" Tag="Store příkaz" Grid.Row="1" Grid.Column="1" Height="36" FontSize="15"/>
                                    <TextBlock Grid.Row="2" Text="Success format" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtAlibiSuccessFormat" Tag="Success format" Grid.Row="2" Grid.Column="1" Height="36" FontSize="15"/>
                                    <TextBlock Grid.Row="3" Text="Echo format" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtAlibiEchoFormat" Tag="Echo format" Grid.Row="3" Grid.Column="1" Height="36" FontSize="15"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border x:Name="PanelUsers" Visibility="Collapsed" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="14" Padding="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Uživatelé" FontSize="18" FontWeight="SemiBold"/>
                                <Grid Padding="8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="190"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="ID" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Grid.Column="1" Text="Uživatel" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Grid.Column="2" Text="Role" FontWeight="SemiBold" FontSize="13"/>
                                </Grid>
                                <ListView x:Name="UsersTable" SelectionMode="Single" MinHeight="260">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid MinHeight="36" Padding="8,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="190"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding IDuser}" FontSize="15" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Username}" FontSize="15" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="2" Text="{Binding RoleName}" FontSize="15" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>
                        <Border x:Name="PanelSystem" Visibility="Collapsed" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="14" Padding="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Systém" FontSize="18" FontWeight="SemiBold"/>
                                <Grid Padding="8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="ID panelu" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtPcId" Tag="ID panelu" Grid.Row="0" Grid.Column="1" Height="36" FontSize="15"/>
                                    <TextBlock Grid.Row="1" Text="Autostart programu" FontSize="15" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="ChkAutoStartWindows" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border x:Name="PanelParameters" Visibility="Collapsed" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="14" Padding="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Parametry" FontSize="18" FontWeight="SemiBold"/>
                                <Grid Padding="8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition x:Name="RowVypocetPodle" Height="44"/>
                                        <RowDefinition Height="44"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Auto start receptury" FontSize="15" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="ChkAutoRecipeStart" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" Text="Automatické tárování" FontSize="15" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="ChkAutoTare" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Text="Vyžadovat přihlášení" FontSize="15" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="ChkLoginRequired" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Text="Max velikost várky" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBox IsReadOnly="True" x:Name="TxtMaxBatchSize" Tag="Max velikost várky" Grid.Row="3" Grid.Column="1" Height="36" FontSize="15"/>
                                    <TextBlock Grid.Row="4" Text="Zobrazit skupiny receptu" FontSize="15" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="ChkZobrazSkupiny" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="5" Text="Povolit přeskočení kroku" FontSize="15" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="ChkPovolitPreskoceni" Grid.Row="5" Grid.Column="1" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="6" Text="Režim základ aktivní" FontSize="15" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="ChkZakladActive" Grid.Row="6" Grid.Column="1" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="7" Text="Výpočet várky" FontSize="15" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="ChkVypocetVarky" Grid.Row="7" Grid.Column="1" VerticalAlignment="Center" Checked="ChkVypocetVarky_Checked" Unchecked="ChkVypocetVarky_Checked"/>
                                    <TextBlock x:Name="TxtVypocetPodle" Grid.Row="8" Text="Výpočet podle" FontSize="15" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    <ComboBox x:Name="CmbVypocetVarkyMode" Grid.Row="8" Grid.Column="1" Height="36" FontSize="15" Visibility="Collapsed">
                                        <ComboBoxItem Content="Podle velikosti receptu"/>
                                        <ComboBoxItem Content="Podle celkové hmotnosti"/>
                                    </ComboBox>
                                    <TextBlock Grid.Row="9" Text="Jednotky" FontSize="15" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="CmbUnits" Grid.Row="9" Grid.Column="1" Height="36" FontSize="15">
                                        <ComboBoxItem Content="Kg"/>
                                        <ComboBoxItem Content="Ks"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Border
                x:Name="InfoToast"
                Margin="0,12,0,0"
                Padding="14,12"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Width="560"
                MaxWidth="560"
                CornerRadius="18"
                BorderThickness="1.5"
                Visibility="Collapsed"
                Canvas.ZIndex="100"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource AccentFillColorDefaultBrush}">

                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>

                <Border.Transitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="-90" IsStaggeringEnabled="False"/>
                    </TransitionCollection>
                </Border.Transitions>

                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="44" Height="44" CornerRadius="14" VerticalAlignment="Center" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                        <Image x:Name="InfoToastIcon" Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" Source="ms-appx:///Assets/MenuIcons/ic_fluent_alert_28_color.svg"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock x:Name="InfoToastTitle" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis" Text="Nastavení"/>
                        <TextBlock x:Name="InfoToastMessage" FontSize="13" LineHeight="18" MaxLines="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Text=""/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </NavigationView>
</Page>
