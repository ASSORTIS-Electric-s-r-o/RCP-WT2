<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="RCP_WT1.Vizualizace.DialogovaOkna.MegeRecipesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Sloučení receptur">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="RootGrid"
        Padding="18"
        RowSpacing="12">

        <Grid.Resources>
            <Style TargetType="Button">
                <Setter Property="Height" Value="46"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="CornerRadius" Value="8"/>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="26"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <Grid
            x:Name="DragArea"
            Grid.Row="0"
            Background="Transparent"/>

        <StackPanel Grid.Row="1" Spacing="6">
            <TextBlock
                Text="Sloučení receptur"
                FontSize="21"
                FontWeight="SemiBold"/>

            <TextBlock
                x:Name="TxtInfo"
                Text="Zadejte množství pro každou recepturu."
                FontSize="14"
                Opacity="0.82"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                CornerRadius="8,8,0,0"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,1,1,0"
                Padding="10,0">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Text="Název receptury"
                        FontSize="14"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"/>

                    <TextBlock
                        x:Name="TxtMnozstviHeader"
                        Grid.Column="1"
                        Text="Množství receptu"
                        FontSize="14"
                        FontWeight="SemiBold"
                        TextAlignment="Center"
                        VerticalAlignment="Center"/>

                    <TextBlock
                        Grid.Column="2"
                        Text=""
                        FontSize="14"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border
                Grid.Row="1"
                CornerRadius="0,0,8,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                <ListView
                    x:Name="RecipesMergeTable"
                    SelectionMode="None"
                    IsItemClickEnabled="True"
                    ItemClick="RecipesMergeTable_ItemClick">

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="40" Padding="10,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Text="{Binding RecipeName}"
                                    FontSize="15"
                                    VerticalAlignment="Center"
                                    TextTrimming="CharacterEllipsis"/>

                                <Grid Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Text="{Binding Velikost}"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>

                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{Binding Jednotka}"
                                        FontSize="14"
                                        Margin="6,0,8,0"
                                        Opacity="0.75"
                                        VerticalAlignment="Center"/>
                                </Grid>

                                <Button
                                    Grid.Column="2"
                                    Content="🗑"
                                    FontSize="18"
                                    Width="46"
                                    Height="38"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Click="OdebratRecipe_Click"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </Grid>

        <Grid Grid.Row="3" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button
                x:Name="BtnPokracovat"
                Grid.Column="0"
                Content="Pokračovat"
                HorizontalAlignment="Stretch"
                IsEnabled="False"
                Click="BtnPokracovat_Click"/>

            <Button
                Grid.Column="1"
                Content="Zavřít"
                HorizontalAlignment="Stretch"
                Click="BtnZrusit_Click"/>
        </Grid>
    </Grid>
</Window>