<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="RCP_WT1.Vizualizace.DialogovaOkna.UsersWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Správa uživatele">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Padding="18">

        <Grid.Resources>

            <Style x:Key="DialogButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="46"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
            </Style>

            <Style x:Key="DialogLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>

        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="26"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <Grid
            x:Name="DragArea"
            Grid.Row="0"
            Background="Transparent"/>

        <StackPanel
            Grid.Row="1"
            Spacing="4">

            <TextBlock
                x:Name="TxtTitle"
                Text="Uživatel"
                FontSize="21"
                FontWeight="SemiBold"
                TextWrapping="WrapWholeWords"/>

            <TextBlock
                x:Name="TxtDescription"
                Text="Vytvoření nebo úprava uživatele"
                FontSize="14"
                TextWrapping="WrapWholeWords"
                Opacity="0.78"/>
        </StackPanel>

        <InfoBar
            x:Name="InfoStatus"
            Grid.Row="2"
            Margin="0,8,0,0"
            IsOpen="False"
            FontSize="13"/>

        <ScrollViewer
            Grid.Row="3"
            Margin="0,10,0,10"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled">

            <StackPanel Spacing="10">

                <StackPanel>
                    <TextBlock
                        Text="Uživatel"
                        Style="{StaticResource DialogLabelStyle}"/>

                    <TextBox
                        x:Name="TxtUsername"
                        Tag="Jméno uživatele"
                        Height="46"
                        FontSize="15"
                        IsReadOnly="False"
                        HorizontalAlignment="Stretch"
                        VerticalContentAlignment="Center"
                        PlaceholderText="Zadejte jméno uživatele"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock
                        Text="Heslo"
                        Style="{StaticResource DialogLabelStyle}"/>

                    <PasswordBox
                        x:Name="TxtPassword"
                        Tag="Heslo uživatele"
                        Height="46"
                        FontSize="15"
                        HorizontalAlignment="Stretch"
                        PlaceholderText="Zadejte heslo"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock
                        Text="Role"
                        Style="{StaticResource DialogLabelStyle}"/>

                    <ComboBox
                        x:Name="CmbRole"
                        MinHeight="46"
                        FontSize="15"
                        HorizontalAlignment="Stretch"
                        VerticalContentAlignment="Center"
                        DisplayMemberPath="Name"
                        SelectedValuePath="IDrole"
                        PlaceholderText="Vyberte roli"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <Grid
            Grid.Row="4"
            ColumnSpacing="10"
            VerticalAlignment="Bottom">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Content="Zrušit"
                Style="{StaticResource DialogButtonStyle}"
                Click="BtnCancel_Click"/>

            <Button
                Grid.Column="1"
                Content="Uložit"
                Style="{StaticResource DialogButtonStyle}"
                Click="BtnSave_Click"/>
        </Grid>

    </Grid>
</Window>