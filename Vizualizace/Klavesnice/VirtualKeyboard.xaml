<?xml version="1.0" encoding="utf-8"?>
<!--
    Okno virtuální klávesnice.
    Obsahuje textovou a numerickou klávesnici, vstupní pole,
    režim hesla a spodní potvrzovací tlačítka.
-->
<Window
    x:Class="RCP_WT1.Vizualizace.Klavesnice.VirtualKeyboard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Virtuální klávesnice">

    <!-- Systémové pozadí okna -->
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <!-- Hlavní rozložení okna klávesnice -->
    <Grid x:Name="RootGrid" Padding="16" RowSpacing="12">

        <!-- Lokální styly tlačítek klávesnice -->
        <Grid.Resources>

            <!-- Výchozí styl běžného tlačítka textové klávesnice -->
            <Style x:Key="KeyboardButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="52"/>
                <Setter Property="Height" Value="46"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="Background" Value="{ThemeResource LayerFillColorAltBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
            </Style>

            <!-- Styl speciálních tlačítek textové klávesnice -->
            <Style x:Key="KeyboardSpecialButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource KeyboardButtonStyle}">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
            </Style>

            <!-- Styl aktivních přepínačů Caps Lock, Shift, DIA a SYM -->
            <Style x:Key="KeyboardActiveButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource KeyboardSpecialButtonStyle}">
                <Setter Property="Background" Value="{ThemeResource SystemControlHighlightAccentBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="{ThemeResource SystemControlHighlightAccentBrush}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
            </Style>

            <!-- Výchozí styl tlačítek numerické klávesnice -->
            <Style x:Key="NumericKeyboardButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="57"/>
                <Setter Property="Height" Value="50"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="Background" Value="{ThemeResource LayerFillColorAltBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
            </Style>

            <!-- Styl speciálních tlačítek numerické klávesnice -->
            <Style x:Key="NumericKeyboardSpecialButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource NumericKeyboardButtonStyle}">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
            </Style>

        </Grid.Resources>

        <!-- Rozdělení okna na titulkovou oblast, nadpis, vstup, klávesnici a spodní akce -->
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Oblast pro tažení okna bez standardního titulku -->
        <Grid
            x:Name="DragArea"
            Grid.Row="0"
            Background="Transparent"/>

        <!-- Volitelný nadpis klávesnice -->
        <TextBlock
            x:Name="TxtKeyboardTitle"
            Grid.Row="1"
            Text=""
            FontSize="20"
            FontWeight="SemiBold"
            MaxHeight="52"
            TextWrapping="WrapWholeWords"
            TextTrimming="CharacterEllipsis"
            Margin="0,0,0,2"/>

        <!-- Textové vstupní pole pro běžný režim -->
        <TextBox
            x:Name="TxtText"
            Grid.Row="2"
            FontSize="28"
            Height="60"
            AcceptsReturn="True"
            TextWrapping="Wrap"
            VerticalContentAlignment="Center"/>

        <!-- Vstupní pole pro režim hesla -->
        <Grid
            x:Name="PwdGrid"
            Grid.Row="2"
            Visibility="Collapsed">

            <!-- Maskované pole hesla -->
            <TextBox
                x:Name="TxtPassword"
                FontSize="28"
                Height="60"
                Padding="12,0,58,0"
                VerticalContentAlignment="Center"/>

            <!-- Dočasné zobrazení hesla -->
            <Button
                x:Name="BtnShowPassword"
                Content="👁"
                Width="46"
                Height="46"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,8,0"
                Click="BtnShowPassword_Click"
                Background="{ThemeResource LayerFillColorAltBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1.5"/>
        </Grid>

        <!-- Numerická klávesnice pro režim INT / FLOAT -->
        <Grid
                x:Name="NumericKeyboardGrid"
                Grid.Row="3"
                Visibility="Collapsed"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Rozdělení okna na titulkovou oblast, nadpis, vstup, klávesnici a spodní akce -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 7 8 9 -->
            <Button Grid.Row="0" Grid.Column="0" Content="7" Tag="7" Style="{StaticResource NumericKeyboardButtonStyle}" Click="Key_Click"/>
            <Button Grid.Row="0" Grid.Column="1" Content="8" Tag="8" Style="{StaticResource NumericKeyboardButtonStyle}" Click="Key_Click"/>
            <Button Grid.Row="0" Grid.Column="2" Content="9" Tag="9" Style="{StaticResource NumericKeyboardButtonStyle}" Click="Key_Click"/>

            <!-- 4 5 6 -->
            <Button Grid.Row="1" Grid.Column="0" Content="4" Tag="4" Style="{StaticResource NumericKeyboardButtonStyle}" Click="Key_Click"/>
            <Button Grid.Row="1" Grid.Column="1" Content="5" Tag="5" Style="{StaticResource NumericKeyboardButtonStyle}" Click="Key_Click"/>
            <Button Grid.Row="1" Grid.Column="2" Content="6" Tag="6" Style="{StaticResource NumericKeyboardButtonStyle}" Click="Key_Click"/>

            <!-- 1 2 3 -->
            <Button Grid.Row="2" Grid.Column="0" Content="1" Tag="1" Style="{StaticResource NumericKeyboardButtonStyle}" Click="Key_Click"/>
            <Button Grid.Row="2" Grid.Column="1" Content="2" Tag="2" Style="{StaticResource NumericKeyboardButtonStyle}" Click="Key_Click"/>
            <Button Grid.Row="2" Grid.Column="2" Content="3" Tag="3" Style="{StaticResource NumericKeyboardButtonStyle}" Click="Key_Click"/>

            <!-- 0 . -->
            <Button Grid.Row="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Width="118"
                    Content="0"
                    Tag="0"
                    Style="{StaticResource NumericKeyboardButtonStyle}"
                    Click="Key_Click"/>

            <Button Grid.Row="3"
                    Grid.Column="2"
                    x:Name="BtnDecimalDot"
                    Content="."
                    Tag="."
                    Style="{StaticResource NumericKeyboardButtonStyle}"
                    Click="Key_Click"/>

            <!-- Backspace -->
            <Button Grid.Row="0"
                    Grid.Column="3"
                    Grid.RowSpan="2"
                    Width="80"
                    Height="104"
                    Content="⌫"
                    Style="{StaticResource NumericKeyboardSpecialButtonStyle}"
                    Click="Backspace_Click"/>

            <!-- Clear -->
            <Button Grid.Row="2"
                    Grid.Column="3"
                    Grid.RowSpan="2"
                    Width="80"
                    Height="104"
                    Content="Clear"
                    Style="{StaticResource NumericKeyboardSpecialButtonStyle}"
                    Click="Clear_Click"/>

        </Grid>

        <!-- Textová klávesnice pro režim STR / PWD -->
        <Viewbox
            x:Name="TextKeyboardView"
            Grid.Row="3"
            Stretch="Uniform"
            StretchDirection="DownOnly"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <!-- Panel s řádky textové klávesnice -->
            <StackPanel x:Name="KlavesnicePanel" Spacing="2">

                <!-- První řádek textové klávesnice: čísla a základní znaky -->
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource KeyboardSpecialButtonStyle}" Content="Esc" Click="BtnCancel_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="1" Tag="1" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="2" Tag="2" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="3" Tag="3" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="4" Tag="4" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="5" Tag="5" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="6" Tag="6" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="7" Tag="7" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="8" Tag="8" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="9" Tag="9" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="0" Tag="0" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="+" Tag="+" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="=" Tag="=" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardSpecialButtonStyle}" Content="Backspace" Width="125" Click="Backspace_Click"/>
                </StackPanel>

                <!-- Druhý řádek textové klávesnice -->
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource KeyboardSpecialButtonStyle}" Content="Tab" Width="90" Tag="    " Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="Q" Tag="q" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="W" Tag="w" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="E" Tag="e" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="R" Tag="r" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="T" Tag="t" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="Z" Tag="z" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="U" Tag="u" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="I" Tag="i" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="O" Tag="o" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="P" Tag="p" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="Ú" Tag="ú" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content=")" Tag=")" Click="Key_Click"/>
                </StackPanel>

                <!-- Třetí řádek textové klávesnice s Caps Lockem -->
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnCapsLock" Style="{StaticResource KeyboardSpecialButtonStyle}" Content="Caps Lock" Width="115" Click="CapsLock_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="A" Tag="a" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="S" Tag="s" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="D" Tag="d" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="F" Tag="f" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="G" Tag="g" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="H" Tag="h" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="J" Tag="j" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="K" Tag="k" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="L" Tag="l" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="Ů" Tag="ů" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="§" Tag="§" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardSpecialButtonStyle}" Content="Enter" Width="125" Click="Enter_Click"/>
                </StackPanel>

                <!-- Čtvrtý řádek textové klávesnice se Shiftem -->
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnShiftLeft" Style="{StaticResource KeyboardSpecialButtonStyle}" Content="Shift" Width="145" Click="Shift_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="Y" Tag="y" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="X" Tag="x" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="C" Tag="c" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="V" Tag="v" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="B" Tag="b" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="N" Tag="n" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="M" Tag="m" Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="," Tag="," Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="." Tag="." Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="-" Tag="-" Click="Key_Click"/>
                    <Button x:Name="BtnShiftRight" Style="{StaticResource KeyboardSpecialButtonStyle}" Content="Shift" Width="145" Click="Shift_Click"/>
                </StackPanel>

                <!-- Spodní řádek textové klávesnice s přepínači DIA, SYM a mezerníkem -->
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnDia" Style="{StaticResource KeyboardSpecialButtonStyle}" Content="DIA" Width="90" Click="Dia_Click"/>
                    <Button x:Name="BtnSym" Style="{StaticResource KeyboardSpecialButtonStyle}" Content="SYM" Width="90" Click="Sym_Click"/>
                    <Button Style="{StaticResource KeyboardButtonStyle}" Content="Mezerník" Width="520" Tag=" " Click="Key_Click"/>
                    <Button Style="{StaticResource KeyboardSpecialButtonStyle}" Content="Clear" Width="90" Click="Clear_Click"/>
                </StackPanel>

            </StackPanel>
        </Viewbox>

        <!-- Spodní akční tlačítka pro potvrzení nebo zrušení zadání -->
        <Grid Grid.Row="4" ColumnSpacing="10" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Content="Zpět"
                Height="58"
                FontSize="22"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Click="BtnCancel_Click"
                Background="{ThemeResource LayerFillColorAltBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1.5"/>

            <Button
                Grid.Column="1"
                Content="OK"
                Height="58"
                FontSize="22"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Click="BtnOK_Click"
                Background="{ThemeResource LayerFillColorAltBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1.5"/>
        </Grid>

    </Grid>
</Window>